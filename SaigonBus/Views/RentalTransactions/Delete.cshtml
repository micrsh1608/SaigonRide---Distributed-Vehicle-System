@model SaigonBus.Models.RentalTransaction

@{
    ViewBag.Title = "Xóa giao dịch";
}

<!-- Nhúng thư viện FontAwesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    /* Ẩn thanh điều hướng mặc định */
    .navbar {
        display: none !important;
    }

    body {
        padding-top: 0 !important;
        background-color: #f4f7f6;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    :root {
        --saigonbus-primary: #00838F;
        --saigonbus-danger: #dc3545;
        --saigonbus-danger-dark: #b02a37;
        --saigonbus-accent: #F39C12;
    }

    /* Tùy chỉnh thanh Nav (Breadcrumb) đồng bộ */
    .custom-breadcrumb-container {
        background-color: #ffffff;
        border-radius: 10px;
        padding: 0.8rem 1.5rem;
        box-shadow: 0 0.25rem 0.5rem rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(0,0,0,0.03);
        margin-bottom: 1.5rem;
        display: inline-flex;
        width: 100%;
    }

        .custom-breadcrumb-container .breadcrumb {
            margin-bottom: 0;
            background: transparent;
            padding: 0;
        }

        .custom-breadcrumb-container .breadcrumb-item a {
            color: #6c757d;
            font-weight: 500;
            text-decoration: none;
            transition: color 0.2s;
        }

            .custom-breadcrumb-container .breadcrumb-item a:hover {
                color: var(--saigonbus-danger);
            }

        .custom-breadcrumb-container .breadcrumb-item.active {
            color: var(--saigonbus-danger);
        }

        .custom-breadcrumb-container .breadcrumb-item + .breadcrumb-item::before {
            content: "›";
            font-size: 1.4em;
            color: #adb5bd;
            padding: 0 0.5rem;
        }

    /* Card & Header Styles (Cảnh báo đỏ) */
    .transaction-card {
        border-radius: 12px;
        border: none;
        box-shadow: 0 0.5rem 1.5rem rgba(220, 53, 69, 0.15);
        overflow: hidden;
        border-top: 4px solid var(--saigonbus-danger);
        background-color: #fff;
    }

        .transaction-card .card-header {
            background-color: #fff;
            border-bottom: 1px solid #f1f2f4;
            padding: 1.5rem;
        }

    /* Alert Style */
    .alert-custom {
        background-color: #fff5f5;
        border-left: 4px solid var(--saigonbus-danger);
        color: #842029;
        border-radius: 8px;
    }

    .alert-critical {
        background-color: #842029;
        color: white;
        border-radius: 8px;
        border: 1px solid #5c161d;
        box-shadow: 0 4px 12px rgba(132, 32, 41, 0.2);
    }

    /* Info Grid */
    .info-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6c757d;
        font-weight: 600;
        margin-bottom: 0.3rem;
    }

    .info-value {
        font-size: 1.15rem;
        color: #2b3d51;
        font-weight: 600;
        margin-bottom: 1.5rem;
    }

    .info-box {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 1.5rem;
        border: 1px solid #e9ecef;
    }

    /* Button Styles */
    .btn-danger-custom {
        background-color: var(--saigonbus-danger);
        color: white;
        border: none;
        padding: 0.8rem 1.5rem;
        transition: all 0.3s ease;
        border-radius: 8px;
        font-weight: bold;
        width: 100%;
    }

        .btn-danger-custom:hover {
            background-color: var(--saigonbus-danger-dark);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
        }

    .btn-outline-back {
        border: 2px solid #dee2e6;
        color: #6c757d;
        font-weight: bold;
        padding: 0.8rem 1.5rem;
        border-radius: 8px;
        transition: all 0.3s;
        text-decoration: none;
        display: inline-block;
        width: 100%;
        text-align: center;
    }

        .btn-outline-back:hover {
            background-color: #f8f9fa;
            color: #343a40;
            border-color: #ced4da;
        }
</style>

<div class="container mt-4 mb-5">
    <!-- Breadcrumb điều hướng -->
    <nav aria-label="breadcrumb" class="custom-breadcrumb-container">
        <ol class="breadcrumb align-items-center">
            <li class="breadcrumb-item"><a href="/"><i class="fas fa-home me-1"></i> Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index")">Quản lý Giao dịch</a></li>
            <li class="breadcrumb-item active fw-bold" aria-current="page">Xóa giao dịch #RT-@Model.TransactionId</li>
        </ol>
    </nav>

    <!-- Ép Form vào giữa màn hình -->
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="transaction-card">
                <div class="card-header text-center pb-2 pt-4">
                    <div class="mb-3">
                        <i class="fas fa-file-invoice-dollar text-danger" style="font-size: 3.5rem;"></i>
                    </div>
                    <h4 class="m-0 text-dark fw-bold">
                        Hủy bỏ Hồ sơ chuyến đi
                    </h4>
                </div>

                <div class="card-body p-4 p-md-5 pt-3">

                    @if (Model.EndTime == null)
                    {
                        <!-- Cảnh báo mức độ nghiêm trọng nếu cuốc xe chưa trả -->
                        <div class="alert alert-critical p-4 mb-4" role="alert">
                            <h5 class="alert-heading fw-bold mb-2"><i class="fas fa-exclamation-triangle me-2"></i> RỦI RO NGHIÊM TRỌNG!</h5>
                            <p class="mb-0" style="font-size: 0.95rem; line-height: 1.6;">
                                Giao dịch này <strong>chưa được hoàn tất (khách vẫn đang thuê xe)</strong>. Nếu bạn xóa lúc này, hệ thống sẽ mất dấu phương tiện <strong>#@Model.VehicleId</strong> và không thể thu tiền khách hàng. Vui lòng cân nhắc kỹ trước khi thực hiện!
                            </p>
                        </div>
                    }
                    else
                    {
                        <!-- Cảnh báo thông thường -->
                        <div class="alert alert-custom p-3 mb-4 shadow-sm" role="alert">
                            <h6 class="alert-heading fw-bold mb-1"><i class="fas fa-exclamation-circle me-1"></i> Cảnh báo mất dữ liệu kế toán!</h6>
                            <p class="mb-0" style="font-size: 0.95rem;">Bạn đang chuẩn bị xóa vĩnh viễn giao dịch <strong>#RT-@Model.TransactionId</strong>. Hành động này sẽ làm sai lệch doanh thu tổng của hệ thống và không thể hoàn tác.</p>
                        </div>
                    }

                    <!-- Hiển thị tóm tắt thông tin để kiểm tra chéo -->
                    <div class="info-box mb-5 shadow-sm">
                        <h6 class="fw-bold border-bottom pb-2 mb-4 text-secondary">
                            <i class="fas fa-clipboard-check me-1"></i> Dữ liệu kiểm tra chéo
                        </h6>
                        <div class="row">
                            <div class="col-sm-6">
                                <div class="info-label">Mã Giao Dịch</div>
                                <div class="info-value text-danger fw-bold fs-4">#RT-@Model.TransactionId</div>

                                <div class="info-label">Khách hàng</div>
                                <div class="info-value">
                                    <i class="fas fa-user-circle text-muted me-1"></i> USER-@Model.UserId
                                </div>

                                <div class="info-label">Thời gian bắt đầu</div>
                                <div class="info-value" style="font-size: 1rem;">
                                    <i class="far fa-clock text-muted me-1"></i> @Model.StartTime.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="info-label">Phương tiện</div>
                                <div class="info-value">
                                    <i class="fas fa-bicycle text-muted me-1"></i> VH-@Model.VehicleId
                                </div>

                                <div class="info-label">Tình trạng</div>
                                <div class="info-value">
                                    @if (Model.EndTime != null)
                                    {
                                        <span class="text-success"><i class="fas fa-check-circle me-1"></i> Đã hoàn tất</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning text-dark"><i class="fas fa-biking me-1"></i> Đang chạy</span>
                                    }
                                </div>

                                <div class="info-label">Doanh thu cuốc xe</div>
                                <div class="info-value text-success fs-5">
                                    @(Model.TotalAmount.HasValue ? string.Format("{0:N0} ₫", Model.TotalAmount) : "Chưa chốt giá")
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Nút Thao tác -->
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        <div class="row g-3 mt-2">
                            <div class="col-md-5">
                                <a href="@Url.Action("Index")" class="btn btn-outline-back shadow-sm">
                                    <i class="fas fa-arrow-left me-1"></i> Hủy lệnh xóa
                                </a>
                            </div>
                            <div class="col-md-7">
                                <button type="submit" class="btn btn-danger-custom shadow-sm" @(Model.EndTime == null ? "onclick=\"return confirm('CẢNH BÁO TỐI CAO: Khách vẫn đang chạy xe. Bạn CHẮC CHẮN muốn xóa để mất dấu xe không?');\"" : "")>
                                    <i class="fas fa-trash-alt me-1"></i> Xác nhận xóa vĩnh viễn
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>