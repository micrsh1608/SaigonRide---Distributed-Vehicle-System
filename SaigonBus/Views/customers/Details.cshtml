@model SaigonBus.Models.User

@{
    ViewBag.Title = "Chi tiết Khách hàng";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white p-4">
            <h4 class="mb-0"><i class="fas fa-user-circle me-2"></i>Thông tin chi tiết khách hàng</h4>
        </div>
        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-md-4 text-center border-end">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 120px; height: 120px;">
                        <i class="fas fa-user fa-4x text-muted"></i>
                    </div>
                    <h3 class="fw-bold">@Model.FullName</h3>
                    <span class="badge bg-success rounded-pill px-3">Active</span>
                </div>
                <div class="col-md-8">
                    <table class="table table-borderless">
                        <tr>
                            <th class="text-muted" style="width: 200px;">ID Hệ thống:</th>
                            <td class="fw-bold">#CUS-@Model.UserId</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Username:</th>
                            <td class="fw-bold text-primary">@Model.Username</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Số điện thoại:</th>
                            <td class="fw-bold">@Model.Phone</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Số dư ví:</th>
                            <td class="fw-bold text-success fs-4">@Model.Balance.ToString("N0") ₫</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Địa chỉ Email:</th>
                            <td class="fw-bold">@Model.Email</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Số CCCD/CMND:</th>
                            <td class="fw-bold">@(string.IsNullOrEmpty(Model.CCCD) ? "N/A" : Model.CCCD)</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Số Hộ chiếu:</th>
                            <td class="fw-bold">@(string.IsNullOrEmpty(Model.Passport) ? "N/A" : Model.Passport)</td>
                        </tr>
                    </table>
                </div>
            </div>
            <hr />
            <div class="d-flex justify-content-between">
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary px-4 rounded-pill"><i class="fas fa-arrow-left me-2"></i>Quay lại</a>
                <div>
                    <a href="@Url.Action("Edit", new { id = Model.UserId })" class="btn btn-primary px-4 rounded-pill"><i class="fas fa-edit me-2"></i>Chỉnh sửa</a>
                    <a href="@Url.Action("Delete", new { id = Model.UserId })" class="btn btn-danger px-4 rounded-pill"><i class="fas fa-trash-alt me-2"></i>Xóa</a>
                </div>
            </div>
        </div>
    </div>
</div>
