@model SaigonBus.Models.User

@{
    ViewBag.Title = "Xóa Khách hàng";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow-sm rounded-4">
                <div class="card-body p-5 text-center">
                    <div class="text-danger mb-4">
                        <i class="fas fa-exclamation-triangle fa-4x"></i>
                    </div>
                    <h2 class="fw-bold text-danger mb-3">Xác nhận xóa tài khoản?</h2>
                    <p class="text-muted mb-4">
                        Bạn đang chuẩn bị xóa vĩnh viễn tài khoản của khách hàng <br />
                        <strong>@Model.FullName</strong> (ID: #CUS-@Model.UserId). <br />
                        Hành động này không thể hoàn tác.
                    </p>
                    
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold py-3">Xác nhận Xóa vĩnh viễn</button>
                            <a href="@Url.Action("Index")" class="btn btn-light btn-lg rounded-pill fw-bold py-3 text-secondary">Hủy bỏ & Quay lại</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
