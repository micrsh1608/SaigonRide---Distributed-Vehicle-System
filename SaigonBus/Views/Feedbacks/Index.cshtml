@model IEnumerable<SaigonBus.Models.Feedback>

@{
    ViewBag.Title = "Feedback";
}

<div class="container">

    <h2>
        User Feedback
    </h2>

    @foreach (var item in Model)
    {
        <div class="card">

            <h3>
                @item.Username
            </h3>

            <p>
                @item.Note
            </p>

            <span>
                Rating:
                @item.Rating ⭐
            </span>

        </div>
    }

</div>
