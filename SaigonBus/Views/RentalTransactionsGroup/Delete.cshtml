@model SaigonBus.Models.GroupRental

@{
    ViewBag.Title = "Xóa Giao dịch Nhóm";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow-sm rounded-4">
                <div class="card-body p-5 text-center">
                    <div class="text-danger mb-4">
                        <i class="fas fa-trash-alt fa-4x"></i>
                    </div>
                    <h2 class="fw-bold text-danger mb-3">Xác nhận xóa giao dịch?</h2>
                    <p class="text-muted mb-4">
                        Bạn đang chuẩn bị xóa bản ghi giao dịch thuê xe nhóm <br />
                        <strong>#GRP-@Model.GroupRentalId</strong>. <br />
                        Việc này sẽ không ảnh hưởng đến số dư ví đã trừ, chỉ xóa lịch sử.
                    </p>
                    
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold py-3">Xác nhận Xóa lịch sử</button>
                            <a href="@Url.Action("Index")" class="btn btn-light btn-lg rounded-pill fw-bold py-3 text-secondary">Hủy bỏ</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
