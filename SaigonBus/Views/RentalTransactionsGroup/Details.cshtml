@model SaigonBus.Models.GroupRental

@{
    ViewBag.Title = "Chi tiết Thuê Nhóm";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-info text-white p-4">
            <h4 class="mb-0"><i class="fas fa-users-cog me-2"></i>Chi tiết giao dịch thuê xe nhóm #GRP-@Model.GroupRentalId</h4>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-6 border-end">
                    <h5 class="fw-bold text-primary mb-3"><i class="fas fa-info-circle me-2"></i>Thông tin tổng quan</h5>
                    <table class="table table-sm">
                        <tr><th class="text-muted">Người đại diện:</th><td class="fw-bold">@Model.User.FullName</td></tr>
                        <tr><th class="text-muted">Số lượng xe:</th><td class="fw-bold"><span class="badge bg-primary rounded-pill">@Model.Quantity xe</span></td></tr>
                        <tr><th class="text-muted">Loại xe:</th><td class="fw-bold">@(Model.VehicleCategory == "EBike" ? "Xe điện" : "Xe đạp")</td></tr>
                        <tr><th class="text-muted">Tổng phí:</th><td class="fw-bold text-success">@Model.TotalAmount.ToString("N0") ₫</td></tr>
                        <tr><th class="text-muted">Trạng thái:</th><td><span class="badge bg-warning text-dark">@Model.Status</span></td></tr>
                    </table>
                </div>
                <div class="col-md-6 ps-4">
                    <h5 class="fw-bold text-primary mb-3"><i class="fas fa-map-marker-alt me-2"></i>Lộ trình di chuyển</h5>
                    <table class="table table-sm">
                        <tr><th class="text-muted">Trạm nhận:</th><td class="fw-bold text-info">@Model.StartStation.LocationName</td></tr>
                        <tr><th class="text-muted">Trạm trả dự kiến:</th><td class="fw-bold text-info">@(Model.EndStation != null ? Model.EndStation.LocationName : "N/A")</td></tr>
                        <tr><th class="text-muted">Giờ bắt đầu:</th><td>@Model.StartTime.ToString("HH:mm dd/MM/yyyy")</td></tr>
                        <tr><th class="text-muted">Giờ kết thúc:</th><td>@(Model.EndTime?.ToString("HH:mm dd/MM/yyyy") ?? "---")</td></tr>
                    </table>
                </div>
            </div>

            <hr />
            <div class="d-flex justify-content-between">
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary px-4 rounded-pill"><i class="fas fa-arrow-left me-2"></i>Quay lại</a>
                <a href="@Url.Action("Delete", new { id = Model.GroupRentalId })" class="btn btn-outline-danger px-4 rounded-pill"><i class="fas fa-trash-alt me-2"></i>Xóa giao dịch</a>
            </div>
        </div>
    </div>
</div>
