@model SaigonBus.Models.Vehicle

@{
    ViewBag.Title = "Chi tiết phương tiện";
}

<!-- Nhúng thư viện FontAwesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    body {
        background-color: #f4f7f6;
    }

    :root {
        --saigonbus-primary: #00838F;
        --saigonbus-primary-dark: #006064;
        --saigonbus-accent: #F39C12;
        --saigonbus-accent-hover: #E67E22;
        --saigonbus-light: #E0F7FA;
    }

    /* Tùy chỉnh thanh Nav (Breadcrumb) đồng bộ với trang Index và Edit */
    .custom-breadcrumb-container {
        background-color: #ffffff;
        border-radius: 10px;
        padding: 0.8rem 1.5rem;
        box-shadow: 0 0.25rem 0.5rem rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(0,0,0,0.03);
        margin-bottom: 1.5rem;
        display: inline-flex;
        width: 100%;
    }

    .custom-breadcrumb-container .breadcrumb {
        margin-bottom: 0;
        background: transparent;
        padding: 0;
    }

    .custom-breadcrumb-container .breadcrumb-item a {
        color: #6c757d;
        font-weight: 500;
        text-decoration: none;
        transition: color 0.2s ease-in-out;
    }

    .custom-breadcrumb-container .breadcrumb-item a:hover {
        color: var(--saigonbus-accent);
    }

    .custom-breadcrumb-container .breadcrumb-item.active {
        color: var(--saigonbus-primary);
    }

    .custom-breadcrumb-container .breadcrumb-item + .breadcrumb-item::before {
        content: "›";
        font-size: 1.4em;
        line-height: 1;
        color: #adb5bd;
        vertical-align: middle;
        padding: 0 0.5rem;
    }

    /* Card & Header Styles */
    .vehicle-card {
        border-radius: 12px;
        border: none;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }

        .vehicle-card .card-header {
            background: linear-gradient(135deg, var(--saigonbus-primary) 0%, var(--saigonbus-primary-dark) 100%);
            border-bottom: none;
            padding: 1.5rem;
            color: white;
        }

    /* Info Grid */
    .detail-row {
        border-bottom: 1px dashed #e9ecef;
        padding: 1.2rem 0;
    }

    .detail-row:last-child {
        border-bottom: none;
    }

    .detail-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #8e9bb0;
        font-weight: 700;
        margin-bottom: 0.4rem;
    }

    .detail-value {
        font-size: 1.15rem;
        color: #2b3d51;
        font-weight: 500;
    }

    /* Badge */
    .badge-status {
        font-size: 0.85em;
        padding: 0.5em 1em;
        border-radius: 30px;
        letter-spacing: 0.5px;
    }

    /* Button Styles */
    .btn-accent {
        background-color: var(--saigonbus-accent);
        color: white;
        border: none;
        padding: 0.6rem 1.5rem;
        transition: all 0.3s ease;
        border-radius: 8px;
        font-weight: bold;
    }

    .btn-accent:hover {
        background-color: var(--saigonbus-accent-hover);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(243, 156, 18, 0.3);
    }

    .btn-outline-back {
        border: 2px solid #dee2e6;
        color: #6c757d;
        font-weight: bold;
        padding: 0.6rem 1.5rem;
        border-radius: 8px;
        transition: all 0.3s;
    }

    .btn-outline-back:hover {
        background-color: #f8f9fa;
        color: var(--saigonbus-primary-dark);
        border-color: #ced4da;
    }

    .text-brand {
        color: var(--saigonbus-primary) !important;
    }

    .icon-circle {
        width: 55px;
        height: 55px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: rgba(255,255,255,0.15);
        border: 2px solid rgba(255,255,255,0.3);
    }
</style>

<div class="container mt-4 mb-5">
    <!-- Breadcrumb điều hướng (Đã được nâng cấp) -->
    <nav aria-label="breadcrumb" class="custom-breadcrumb-container">
        <ol class="breadcrumb align-items-center">
            <li class="breadcrumb-item">
                <a href="/"><i class="fas fa-home me-1"></i> Trang chủ</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index")">Quản lý Xe (Fleet)</a>
            </li>
            <li class="breadcrumb-item active fw-bold" aria-current="page">
                Hồ sơ xe #@Model.VehicleId
            </li>
        </ol>
    </nav>

    <!-- Ép Form vào giữa màn hình -->
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <div class="card vehicle-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="m-0 text-white" style="font-weight: 600; letter-spacing: 0.5px;">
                            <i class="fas fa-info-circle me-2"></i> Hồ sơ phương tiện
                        </h4>
                        <p class="mb-0 mt-1" style="font-size: 0.9em; opacity: 0.85;">Xem thông tin chi tiết của xe định danh <strong>#@Model.VehicleId</strong></p>
                    </div>
                    <!-- Biểu tượng nổi bật trên góc Card -->
                    <div class="icon-circle shadow-sm">
                        @if (Model.Category == SaigonBus.Models.VehicleCategory.StandardBike)
                        {<i class="fas fa-bicycle text-white fs-4"></i> }
                        else if (Model.Category == SaigonBus.Models.VehicleCategory.EBike)
                        { <i class="fas fa-bolt text-warning fs-4"></i> }
                        else
                        { <i class="fas fa-motorcycle text-white fs-4"></i>}
                    </div>
                </div>

                <div class="card-body p-4 p-md-5">

                    <!-- Box xám nổi bật chứa thông tin cốt lõi -->
                    <div class="bg-light p-4 rounded mb-4 border">
                        <div class="row text-center">
                            <div class="col-6 border-end">
                                <div class="detail-label"><i class="fas fa-hashtag me-1"></i> Mã hệ thống</div>
                                <div class="detail-value text-brand fw-bold" style="font-size: 1.5rem;">#@Model.VehicleId</div>
                            </div>
                            <div class="col-6">
                                <div class="detail-label"><i class="fas fa-tag me-1"></i> Phân loại</div>
                                <div class="detail-value fw-bold mt-2 text-dark">
                                    @Html.DisplayFor(model => model.Category)
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Phần chi tiết hoạt động -->
                    <div class="px-2">
                        <div class="detail-row">
                            <div class="row align-items-center">
                                <div class="col-sm-5 detail-label mb-0"><i class="fas fa-traffic-light text-muted me-2"></i> Tình trạng hiện tại</div>
                                <div class="col-sm-7 detail-value">
                                    @if (Model.Status == SaigonBus.Models.VehicleStatus.Available)
                                    {
                                        <span class="badge badge-status" style="background-color: #d1e7dd; color: #0f5132; border: 1px solid #badbcc;"><i class="fas fa-check-circle me-1"></i> Sẵn sàng phục vụ</span>
                                    }
                                    else if (Model.Status == SaigonBus.Models.VehicleStatus.InTransit)
                                    {
                                        <span class="badge badge-status" style="background-color: #cfe2ff; color: #084298; border: 1px solid #b6d4fe;"><i class="fas fa-route me-1"></i> Đang được khách thuê</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-status" style="background-color: #f8d7da; color: #842029; border: 1px solid #f5c2c7;"><i class="fas fa-tools me-1"></i> Đang bảo trì / Sửa chữa</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="detail-row">
                            <div class="row align-items-center">
                                <div class="col-sm-5 detail-label mb-0"><i class="fas fa-map-marker-alt text-danger me-2"></i> Vị trí kho bãi (Đỗ xe)</div>
                                <div class="col-sm-7 detail-value">
                                    @if (Model.CurrentStation != null)
                                    {
                                        <span class="text-dark fw-bold"><i class="fas fa-building me-2 text-muted"></i>@Html.DisplayFor(model => model.CurrentStation.LocationName)</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic"><i class="fas fa-spinner fa-spin me-2 text-warning"></i>Đang lưu thông trên đường</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Nút Thao tác -->
                    <hr class="mb-4 mt-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <a href="@Url.Action("Index")" class="btn btn-outline-back text-decoration-none">
                            <i class="fas fa-arrow-left me-1"></i> Trở về danh sách
                        </a>
                        <a href="@Url.Action("Edit", new { id = Model.VehicleId })" class="btn btn-accent shadow-sm text-decoration-none">
                            <i class="fas fa-edit me-1"></i> Chỉnh sửa thông tin
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>