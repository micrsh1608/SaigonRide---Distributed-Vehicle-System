@model IEnumerable<SaigonBus.Models.SupportRequest>

@{
    ViewBag.Title = "Yêu cầu Hỗ trợ";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    body {
        background-color: #f4f7f6;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    :root {
        --saigonbus-primary: #00838F;
        --saigonbus-danger: #dc3545;
    }

    .custom-breadcrumb-container {
        background-color: #ffffff;
        border-radius: 10px;
        padding: 0.8rem 1.5rem;
        box-shadow: 0 0.25rem 0.5rem rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(0,0,0,0.03);
        margin-bottom: 1.5rem;
        display: inline-flex;
        width: 100%;
    }

        .custom-breadcrumb-container .breadcrumb {
            margin-bottom: 0;
            background: transparent;
            padding: 0;
        }

        .custom-breadcrumb-container .breadcrumb-item a {
            color: #6c757d;
            font-weight: 500;
            text-decoration: none;
            transition: color 0.2s;
        }

            .custom-breadcrumb-container .breadcrumb-item a:hover {
                color: var(--saigonbus-danger);
            }

        .custom-breadcrumb-container .breadcrumb-item.active {
            color: var(--saigonbus-primary);
        }

        .custom-breadcrumb-container .breadcrumb-item + .breadcrumb-item::before {
            content: "›";
            font-size: 1.4em;
            color: #adb5bd;
            padding: 0 0.5rem;
        }

    .table-card {
        border-radius: 12px;
        border: none;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.08);
        overflow: hidden;
        background: #fff;
    }

        .table-card .card-header {
            background: linear-gradient(135deg, #dc3545 0%, #b02a37 100%);
            padding: 1.5rem;
            border-bottom: none;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
        }

    .custom-table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        border-bottom: 2px solid #e9ecef;
        padding: 1rem 0.5rem;
    }

    .custom-table td {
        padding: 1rem 0.5rem;
        vertical-align: middle;
        color: #2c3e50;
        border-bottom: 1px solid #f1f2f4;
    }

    .btn-resolve {
        background-color: #ffebee;
        color: #dc3545;
        font-weight: bold;
        padding: 0.4rem 1rem;
        border-radius: 8px;
        border: 1px solid #ffcdd2;
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-resolve:hover {
            background-color: #dc3545;
            color: white;
        }
</style>

<div class="container mt-4 mb-5">
    <nav aria-label="breadcrumb" class="custom-breadcrumb-container">
        <ol class="breadcrumb align-items-center">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")"><i class="fas fa-home me-1"></i> Trang chủ</a></li>
            <li class="breadcrumb-item active fw-bold" aria-current="page">Yêu cầu Hỗ trợ</li>
        </ol>
    </nav>

    <div class="table-card">
        <div class="card-header">
            <div>
                <h4 class="m-0 fw-bold"><i class="fas fa-headset me-2"></i> Hệ thống Tiếp nhận Khiếu nại</h4>
                <p class="mb-0 mt-1 text-white-50" style="font-size: 0.9rem;">Xử lý sự cố lỗi xe, sai sót thanh toán từ khách hàng</p>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 custom-table">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4">Mã Phiếu</th>
                            <th>Khách hàng</th>
                            <th style="width: 40%;">Nội dung báo cáo</th>
                            <th>Thời gian gửi</th>
                            <th>Tình trạng</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-danger">#TK-@item.RequestId</td>
                                <td>
                                    <i class="fas fa-user-circle text-muted me-1"></i>
                                    @(item.User != null ? item.User.FullName : "Khách ẩn danh")
                                    @if (item.User != null)
                                    {<br /><small class="text-muted">(@item.User.Username)</small>}
                                </td>
                                <td>
                                    <div class="fw-bold text-dark" style="font-size: 0.9rem;">@item.Subject</div>
                                    <div class="small text-muted text-truncate" style="max-width: 300px;">@item.Content</div>
                                </td>
                                <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (item.Status == "Pending")
                                    {
                                        <span class="badge bg-danger rounded-pill px-2" id="badge-@item.RequestId">Chờ xử lý</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-25 text-success rounded-pill px-2">Đã giải quyết</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        @if (item.Status == "Pending")
                                        {
                                            <button onclick="resolveRequest(@item.RequestId, this)" class="btn-resolve shadow-sm border-0"><i class="fas fa-reply me-1"></i> Xử lý ngay</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-light text-muted border fw-bold px-3 py-1" style="border-radius: 8px;" disabled><i class="fas fa-check me-1"></i> Hoàn tất</button>
                                        }
                                        <a href="@Url.Action("Details", "Supports", new { id = item.RequestId })" class="btn btn-outline-info btn-sm rounded-3 px-2 py-1"><i class="fas fa-eye"></i></a>
                                        <a href="@Url.Action("Delete", "Supports", new { id = item.RequestId })" class="btn btn-outline-danger btn-sm rounded-3 px-2 py-1"><i class="fas fa-trash-alt"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">Chưa có yêu cầu hỗ trợ nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function resolveRequest(id, btn) {
        if(confirm('Xác nhận đã xử lý xong yêu cầu này?')) {
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang xử lý...';
            btn.disabled = true;
            fetch('@Url.Action("ResolveRequest", "Supports")/' + id, {
                method: 'POST'
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    location.reload();
                } else {
                    alert('Có lỗi xảy ra!');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-reply me-1"></i> Xử lý ngay';
                }
            });
        }
    }
</script>
                </table>
            </div>
        </div>
    </div>
</div>