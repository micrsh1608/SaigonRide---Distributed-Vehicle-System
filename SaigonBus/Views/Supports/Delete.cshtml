@model SaigonBus.Models.SupportRequest

@{
    ViewBag.Title = "Xóa Yêu cầu Hỗ trợ";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow-sm rounded-4">
                <div class="card-body p-5 text-center">
                    <div class="text-danger mb-4">
                        <i class="fas fa-trash-alt fa-4x"></i>
                    </div>
                    <h2 class="fw-bold text-danger mb-3">Xóa vĩnh viễn phiếu?</h2>
                    <p class="text-muted mb-4">
                        Bạn đang xóa phiếu hỗ trợ <strong>#TK-@Model.RequestId</strong> <br />
                        của khách hàng <strong>@Model.User.FullName</strong>. <br />
                        Hành động này sẽ xóa vĩnh viễn dữ liệu khiếu nại này.
                    </p>
                    
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold py-3">Xác nhận Xóa</button>
                            <a href="@Url.Action("Index")" class="btn btn-light btn-lg rounded-pill fw-bold py-3 text-secondary">Hủy bỏ</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
