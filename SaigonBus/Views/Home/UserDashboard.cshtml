                                                <path d="M0,0 L18,13 M18,0 L0,13" stroke="#C8102E" stroke-width="1.4" />
                                                <path d="M9,0 V13 M0,6.5 H18" stroke="#fff" stroke-width="3.5" />
                                                <path d="M9,0 V13 M0,6.5 H18" stroke="#C8102E" stroke-width="2.1" />
