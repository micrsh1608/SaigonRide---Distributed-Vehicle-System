                <div class="radio-option selected" onclick="selectPaymentMethod(this, 'momo')">
                    <input type="radio" name="topup-method" value="momo" checked>
                    <img src="https://img.mservice.com.vn/app/img/portal_documents/mini-app_design-guideline_branding-guide-2-2.png" class="pay-logo">
                    <div class="flex-grow-1">
                        <div class="fw-bold">Ví MoMo</div>
                        <div class="small text-muted">Thanh toán tự động (Local)</div>
                    </div>
                </div>

                <div class="radio-option" onclick="selectPaymentMethod(this, 'zalopay')">
                    <input type="radio" name="topup-method" value="zalo">
                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQTlp4qW2M8xPofmuZHwEfGi9mNMWUG0zs53A&s" class="pay-logo" style="border-radius: 8px;">
                    <div class="flex-grow-1">
                        <div class="fw-bold">ZaloPay</div>
                        <div class="small text-muted">Liên kết Zalo (Local)</div>
                    </div>
                </div>

                <div class="radio-option" onclick="selectPaymentMethod(this, 'visa')">
                    <input type="radio" name="topup-method" value="visa">
                    <div class="d-flex align-items-center justify-content-center text-primary bg-white border rounded shadow-sm" style="width: 40px; height: 35px; margin-right: 15px;">
                        <i class="fab fa-cc-visa fs-4"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="fw-bold">Visa / Mastercard</div>
                        <div class="small text-muted">For Foreigners</div>
                    </div>
                </div>

                <div class="mt-4">
                    <label class="form-label-mini">Số tiền cần nạp (VNĐ)</label>
                    <input type="number" id="topup-amount" class="form-control py-3 rounded-4 bg-light" placeholder="Ví dụ: 50000" style="font-size: 1.2rem; font-weight: bold; border: 2px solid #e2e8f0; outline: none;">
                </div>

                <button class="btn btn-success w-100 fw-bold py-3 mt-4 shadow" style="border-radius: 14px;" onclick="processTopup()">
                    <i class="fas fa-lock me-2"></i>Thanh toán an toàn
                </button>
            </div>
        </div>
    </div>

    <div id="admin-login-modal" class="modal-overlay">
        <div class="modal-card text-center p-5">
            <button class="btn-close-modal" onclick="closeModal('admin-login-modal')"><i class="fas fa-times"></i></button>
            <div class="bg-danger bg-opacity-10 d-inline-block p-4 rounded-circle mb-4">
                <i class="fas fa-user-shield text-danger" style="font-size: 3.5rem;"></i>
            </div>
            <h3 class="fw-bold text-danger mb-2">Khu vực Quản trị</h3>
            <p class="text-muted mb-4">Bạn đang yêu cầu truy cập vào hệ thống nội bộ của Saigon EcoRide.</p>
            <button class="btn btn-danger w-100 fw-bold py-3 rounded-4 shadow" onclick="window.location.href='@Url.Action("Login", "Account")'">Đăng nhập Admin</button>
        </div>
    </div>

    <div id="group-modal" class="modal-overlay">
        <div class="modal-card">
            <button class="btn-close-modal" onclick="closeModal('group-modal')"><i class="fas fa-times"></i></button>
            <h4 class="fw-bold mb-1">Thuê xe nhóm</h4>
            <p class="text-muted small mb-4">Thuê nhiều xe cùng lúc với một tài khoản</p>

            <label class="fw-bold small text-muted mb-2">CHỌN TRẠM</label>
            <select id="group-station" class="form-control-custom">
                @* Dữ liệu trạm sẽ được đổ vào đây bằng JS *@
            </select>

            <label class="fw-bold small text-muted mb-2">LOẠI XE</label>
            <select id="group-category" class="form-control-custom">
                <option value="StandardBike">Xe đạp thường (1000đ/cuốc)</option>
                <option value="EBike">Xe đạp điện (1500đ/cuốc)</option>
                <option value="Scooter">Scooter điện (1000đ/cuốc)</option>
            </select>

            <label class="fw-bold small text-muted mb-2">TRẠM DỰ KIẾN TRẢ </label>
            <select id="group-end-station" class="form-control-custom">
                @* Dữ liệu trạm sẽ được đổ vào đây bằng JS *@
            </select>

            <label class="fw-bold small text-muted mb-2">SỐ LƯỢNG XE</label>
            <input type="number" id="group-quantity" class="form-control-custom" value="2" min="1">

            <div id="group-error" class="text-danger small mb-3 d-none"></div>

            <button class="btn btn-primary w-100 fw-bold py-3 shadow" style="background: var(--sg-primary); border: none; border-radius: 14px;" onclick="handleGroupRentalSubmit()">
                <i class="fas fa-users me-2"></i>Xác nhận thuê nhóm
            </button>
        </div>
    </div>
    <div id="notification-modal" class="modal-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:1050; padding-top:80px; overflow-y:auto;">
        <div style="background:#fff; width:92%; max-width:420px; border-radius:20px; overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,0.2); margin:0 auto;">

            <div style="background:linear-gradient(135deg,#00897b,#00695c); padding:18px 20px; display:flex; align-items:center; justify-content:space-between;">
                <div style="display:flex; align-items:center; gap:10px;">
                    <div style="width:36px; height:36px; background:rgba(255,255,255,0.2); border-radius:10px; display:flex; align-items:center; justify-content:center;">
                        <i class="fas fa-gift" style="color:#fbbf24; font-size:16px;"></i>
                    </div>
                    <div>
                        <div style="color:#fff; font-weight:700; font-size:15px;">Ưu đãi trả xe</div>
                        <div style="color:rgba(255,255,255,0.75); font-size:12px;">Trạm thiếu xe — giảm 15% + thưởng điểm</div>
                    </div>
                </div>
                <button onclick="closeModal('notification-modal')" style="background:rgba(255,255,255,0.2); border:none; border-radius:8px; width:30px; height:30px; color:#fff; cursor:pointer;">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div style="background:#fffbeb; border-bottom:1px solid #fde68a; padding:10px 16px; display:flex; align-items:center; gap:8px;">
                <i class="fas fa-info-circle" style="color:#d97706;"></i>
                <span style="font-size:12px; color:#92400e;">
                    Trả xe về trạm dưới đây: <strong>giảm 15% cước</strong> và <strong>+50 điểm thưởng</strong> ngay!
                </span>
            </div>

            <div id="notification-list" style="max-height:380px; overflow-y:auto; padding:12px 14px;">
                <div style="text-align:center; padding:24px; color:#94a3b8;">
                    <i class="fas fa-spinner fa-spin" style="font-size:20px; display:block; margin-bottom:8px;"></i>
                    Đang kiểm tra ưu đãi...
                </div>
            </div>

            <!-- Footer -->
            <div style="padding:12px 16px; border-top:1px solid #f1f5f9; text-align:center;">
                <span style="font-size:11px; color:#94a3b8;">
                    <i class="fas fa-sync-alt me-1"></i>Tự động cập nhật mỗi 60 giây
                </span>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/Scripts/lang.js"></script>
    <script src="~/Scripts/map.js"></script>

    <script>
        let balance = @(ViewBag.Balance != null ? ViewBag.Balance : 0);
        let isRiding = false;
        let rideInterval = null;
        let rideTimeInSeconds = 0;
        let currentRate = 1000;
        let currentStartStationId = 0;
        let vehicleType = "Xe đạp";
        let vehicleCategory = "StandardBike";

        let stationsData = [];

        function loadStationsFromDB() {
            fetch('/Stations/GetStationsData')
                .then(r => r.json())
                .then(data => {
                    stationsData.length = 0;
                    data.forEach(s => stationsData.push(s));
                    renderStationsList();
                    populateGroupStations();
                    loadActiveGroupRentals();
                    updateIncentiveUI(data);
                    if (typeof renderStationsOnMap === 'function') renderStationsOnMap(stationsData);
                });
        }

        function populateGroupStations() {
            const selectStart = document.getElementById('group-station');
            const selectEndGroup = document.getElementById('group-end-station');
            const selectEndSingle = document.getElementById('single-end-station');

            const options = stationsData.map(s => `<option value="${s.id}">${translateStationName(s.name)} (${s.currentCount}/${s.capacity})</option>`).join('');

            if (selectStart) selectStart.innerHTML = options;
            if (selectEndGroup) selectEndGroup.innerHTML = options;
            if (selectEndSingle) selectEndSingle.innerHTML = options;
        }

        function formatMoney(amount) { return new Intl.NumberFormat('vi-VN').format(amount) + ' ₫'; }
        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            toast.className = 'toast-msg show';
            toast.querySelector('i').className = type === 'success' ? 'fas fa-check-circle text-success fs-5' : 'fas fa-info-circle text-info fs-5';
            document.getElementById('toast-text').innerText = message;
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        function openModal(id) { document.getElementById(id).style.display = 'flex'; }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; }
        function selectPaymentMethod(el, method) { document.querySelectorAll('.radio-option').forEach(e => e.classList.remove('selected')); el.classList.add('selected'); el.querySelector('input').checked = true; }

        function renderStationsList() {
            const filter = document.getElementById('station-search').value.toLowerCase();
            const listObj = document.getElementById('stations-render-area');
            listObj.innerHTML = '';
            let filtered = stationsData.filter(s => s.name.toLowerCase().includes(filter));
            if (filtered.length === 0) { listObj.innerHTML = `<div class="p-5 text-center text-muted border rounded-4 bg-white"><i class="fas fa-search-minus fs-1 mb-3 opacity-25"></i><br>${t('station_not_found')}</div>`; return; }

            filtered.forEach(s => {
                let counts = { bike: 0, ebike: 0, scooter: 0 };
                s.vehicles.forEach(v => counts[v.type]++);
                const fillPct = s.capacity > 0 ? Math.round((s.currentCount / s.capacity) * 100) : 0;
                const fillColor = fillPct >= 50 ? 'bg-success' : fillPct >= 20 ? 'bg-warning' : 'bg-danger';
                const displayName = translateStationName(s.name);
                let html = `
                    <div class="station-card-list">
                        <div class="station-header d-flex justify-content-between align-items-start">
                            <div>
                                <h5 class="fw-bold m-0 text-primary">${displayName}</h5>
                                <span class="text-danger fw-bold small"><i class="fas fa-location-arrow"></i> ${t('station_near_you')}</span>
                            </div>
                            <div class="text-end">
                                <div class="fw-bold text-dark" style="font-size: 0.85rem;">${t('station_capacity')}: ${s.currentCount}/${s.capacity}</div>
                                <div class="progress mt-1" style="height: 6px; width: 80px; margin-left: auto;">
                                    <div class="progress-bar ${fillColor}" style="width: ${fillPct}%"></div>
                                </div>
                                <div style="font-size:0.7rem;color:#6b7280;margin-top:2px;">${fillPct}% ${t('station_full_pct')}</div>
                            </div>
                        </div>
                        <div class="vehicle-type-grid">
                            <div class="vehicle-type-item ${counts.bike>0?'has-bike':''}"><i class="fas fa-bicycle text-success"></i><div class="v-count">${counts.bike}</div></div>
                            <div class="vehicle-type-item ${counts.ebike>0?'has-bike':''}"><i class="fas fa-bolt text-warning"></i><div class="v-count">${counts.ebike}</div></div>
                            <div class="vehicle-type-item ${counts.scooter>0?'has-bike':''}"><i class="fas fa-motorcycle text-primary"></i><div class="v-count">${counts.scooter}</div></div>
                        </div>
                        <button class="btn w-100 fw-bold py-3" style="background: #e0f2f1; color: var(--sg-primary); border-radius: 14px;" onclick="viewStationVehicles(${s.id})">
                            <i class="fas fa-search me-2"></i> ${t('station_view_detail')}
                        </button>
                    </div>`;
                listObj.insertAdjacentHTML('beforeend', html);
            });
        }

        function viewStationVehicles(stationId) {
            currentStartStationId = stationId;
            let st = stationsData.find(x => x.id === stationId);
            document.getElementById('sd-name').innerText = translateStationName(st.name);
            document.getElementById('sd-dist').innerText = st.dist || t('station_near_you');
            let vList = document.getElementById('sd-vehicle-list');
            vList.innerHTML = '';

            if (!st.vehicles || st.vehicles.length === 0) {
                vList.innerHTML = `
                    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:36px 20px;gap:12px;text-align:center;">
                        <div style="width:72px;height:72px;background:#fef2f2;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                            <i class="fas fa-bicycle" style="font-size:28px;color:#fca5a5;"></i>
                        </div>
                        <div style="font-weight:800;font-size:1.05rem;color:#374151;">${t('station_empty_title')}</div>
                        <div style="font-size:0.85rem;color:#9ca3af;max-width:220px;line-height:1.5;">${t('station_empty_desc')}</div>
                        <button class="btn btn-outline-secondary btn-sm rounded-pill mt-2" onclick="closeModal('station-detail-modal')">
                            <i class="fas fa-search me-1"></i>${t('station_find_other')}
                        </button>
                    </div>`;
                openModal('station-detail-modal');
                return;
            }

            st.vehicles.forEach(v => {
                let icon = v.type==='bike'?'fa-bicycle':v.type==='ebike'?'fa-bolt':'fa-motorcycle';
                let color = v.type==='bike'?'text-success':v.type==='ebike'?'text-warning':'text-primary';
                let actualPrice = (v.type === 'ebike') ? 1500 : (v.type === 'bike' ? 500 : 1000);
                let batHtml = v.bat ? `<span class="badge ${v.bat>20?'bg-success':'bg-danger'} me-2"><i class="fas fa-battery-half"></i> ${v.bat}%</span>` : '';

                vList.innerHTML += `
                    <div class="single-bike-item">
                        <div class="d-flex align-items-center">
                            <div class="bike-img"><i class="fas ${icon} ${color}"></i></div>
                            <div>
                                <div class="fw-bold" style="font-size: 1.1rem;">${v.name} <span class="text-muted small">(${v.id})</span></div>
                                <div class="mt-2">${batHtml}<span class="badge bg-white text-dark border"><i class="fas fa-tag text-danger"></i> ${v.price}${t('per_minute')}</span></div>
                            </div>
                        </div>
                        <div class="d-flex flex-column gap-2">
                            <button class="btn btn-primary fw-bold px-3 rounded-pill btn-sm" onclick="selectVehicleToRent('${v.name}', ${actualPrice})">
                                <i class="fas fa-key me-1"></i>${t('btn_rent_vehicle')}
                            </button>
                            <button class="btn btn-outline-warning fw-bold px-3 rounded-pill btn-sm" onclick="reserveVehicle(${v.id}, '${v.name}')">
                                <i class="fas fa-clock me-1"></i>${t('btn_reserve')}
                            </button>
                        </div>
                    </div>`;
            });
            openModal('station-detail-modal');
        }

        function reserveVehicle(id, name) {
            fetch('/Vehicles/Reserve', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `id=${id}`
            }).then(r => r.json())
              .then(data => {
                  if (data.success) {
                      showToast(data.message, 'success');
                      closeModal('station-detail-modal');
                      // Bắt đầu đếm ngược 15p giả lập trên UI nếu muốn, hoặc chỉ thông báo
                  } else {
                      showToast(data.message, 'info');
                  }
              });
        }

        function handleGroupRentalSubmit() {
            const stationId = document.getElementById('group-station').value;
            const endStationId = document.getElementById('group-end-station').value;
            const category = document.getElementById('group-category').value;
            const quantity = document.getElementById('group-quantity').value;
            const errorDiv = document.getElementById('group-error');

            showRouteBetweenStations(stationId, endStationId);

            errorDiv.classList.add('d-none');

            fetch('/RentalTransactionsGroup/ProcessGroupRental', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `stationId=${stationId}&endStationId=${endStationId}&category=${category}&quantity=${quantity}`
            }).then(r => r.json())
              .then(data => {
                  if (data.success) {
                      showToast(data.message, 'success');
                      closeModal('group-modal');
                      location.reload();
                  } else {
                      if (data.maxAvailable !== undefined) {
                          errorDiv.innerText = data.message;
                          errorDiv.classList.remove('d-none');
                          if (confirm(data.message)) {
                              document.getElementById('group-quantity').value = data.maxAvailable;
                          }
                      } else {
                          alert(data.message);
                      }
                  }
              });
        }

        function selectVehicleToRent(name, price) {
            vehicleType = name;
            currentRate = price;

            if (price === 500) vehicleCategory = "StandardBike";
            else if (price === 1500) vehicleCategory = "EBike";
            else vehicleCategory = "Scooter";

            closeModal('station-detail-modal');
            openModal('qr-modal');
        }

        function handleMainAction() {
            if (!isRiding) {
                currentRate = 500;
                vehicleType = "Xe đạp (Nhanh)";
                vehicleCategory = "StandardBike";
                openModal('qr-modal');
            } else {
                goToCheckOut();
            }
        }

        function simulateQRUnlock() {
            document.getElementById('qr-title').innerHTML = `<i class="fas fa-spinner fa-spin text-warning me-2"></i>Đang mở khóa IoT...`;
            setTimeout(() => {
                document.getElementById('qr-title').innerHTML = `<i class="fas fa-unlock text-success me-2"></i>Mở khóa thành công!`;
                setTimeout(() => { closeModal('qr-modal'); document.getElementById('qr-title').innerText = "Quét QR hoặc chạm NFC"; startRide(); }, 1000);
            }, 2000);
        }

        function processPreBook() {
            closeModal('qr-modal');
            showToast(`Đã giữ chỗ ${vehicleType} trong 15 phút tới!`, 'success');
        }

        function startRide() {
            isRiding = true;
            rideTimeInSeconds = 0;
            updateDOM();
            showToast(`Chuyến đi bắt đầu: ${vehicleType} (${currentRate}đ/p)`, 'success');

            clearInterval(rideInterval);
            rideInterval = setInterval(() => {
                rideTimeInSeconds++;
                let m = Math.floor(rideTimeInSeconds / 60);
                let s = rideTimeInSeconds % 60;
                let display = document.getElementById('ride-clock');
                if(display) {
                    display.innerText = `${m < 10 ? '0'+m : m}:${s < 10 ? '0'+s : s}`;
                }
            }, 1000);
        }

        function goToCheckOut() {
            clearInterval(rideInterval);
            let totalMins = Math.ceil(rideTimeInSeconds / 60) || 1;
            let totalCost = totalMins * currentRate;
            let endStationId = document.getElementById('single-end-station').value;

            // --- TÍNH TOÁN GIẢM GIÁ 15% CHO TRẠM THIẾU XE (<20%) ---
            let discount = 0;
            let endStation = stationsData.find(s => s.id == endStationId);
            if (endStation) {
                let fullness = endStation.currentCount / endStation.capacity;
                if (fullness < 0.2) {
                    discount = totalCost * 0.15;
                }
            }

            localStorage.setItem('checkout_type', vehicleType);
            localStorage.setItem('checkout_category', vehicleCategory);
            localStorage.setItem('checkout_mins', totalMins);
            localStorage.setItem('checkout_rate', currentRate);
            localStorage.setItem('checkout_total', totalCost);
            localStorage.setItem('checkout_discount', discount);
            localStorage.setItem('checkout_final', totalCost - discount);
            localStorage.setItem('user_balance', balance);
            localStorage.setItem('start_station_id', currentStartStationId);
            localStorage.setItem('end_station_id', endStationId);

            window.location.href = '@Url.Action("Payment", "Home")';
        }

        function updateDOM() {
            document.querySelectorAll('.dyn-balance').forEach(el => el.innerText = formatMoney(balance));
            const mainBtn = document.getElementById('main-action-btn');
            const statusContainer = document.getElementById('status-container');

            if (isRiding) {
                mainBtn.className = "btn-pay-now bg-danger";
                mainBtn.innerHTML = `<i class="fas fa-stop-circle me-2"></i>${t('btn_checkout')}`;

                statusContainer.className = "p-4 border rounded-4 bg-white text-center shadow-sm";
                statusContainer.innerHTML = `
                    <div class="text-success fw-bold mb-2 text-uppercase small" style="letter-spacing: 1px;"><i class="fas fa-circle-notch fa-spin me-2"></i>Đang di chuyển</div>
                    <div class="font-monospace fw-bold text-primary mb-2" id="ride-clock" style="font-size: 3rem; letter-spacing: 2px;">00:00</div>
                    <div class="small text-dark fw-bold bg-light border px-4 py-2 rounded-pill d-inline-block shadow-sm">
                        <i class="fas fa-tag text-danger me-1"></i> ${vehicleType} • ${currentRate}đ/phút
                    </div>
                `;
            } else {
                mainBtn.className = "btn-pay-now";
                mainBtn.innerHTML = `<i class="fas fa-qrcode me-2"></i>${t('btn_rent')}`;

                statusContainer.className = "p-4 border rounded-4 bg-light text-center";
                statusContainer.innerHTML = `
                    <i class="fas fa-bicycle fs-1 text-muted mb-3 opacity-25"></i>
                    <h6 class="fw-bold text-dark m-0" data-i18n="status_no_trip">Chưa có chuyến đi</h6>
                    <p class="text-muted small mt-1" data-i18n="status_scan_qr">Quét mã QR tại trạm để bắt đầu.</p>
                `;
            }
        }

        function processTopup() {
            let amt = parseInt(document.getElementById('topup-amount').value);
            if (!amt) { showToast('Vui lòng nhập số tiền', 'info'); return; }

            closeModal('gateway-modal');
            showToast(`Đang kết nối cổng thanh toán...`, 'info');
            setTimeout(() => {
                balance += amt;
                localStorage.setItem('user_balance', balance);
                updateDOM();
                showToast(`Nạp thành công ${formatMoney(amt)}!`);
                document.getElementById('topup-amount').value='';
            }, 1500);
        }

        let groupTimers = {};

        function loadActiveGroupRentals() {
            fetch('/RentalTransactionsGroup/GetActiveGroupRentals')
                .then(r => r.json())
                .then(data => {
                    const section = document.getElementById('active-group-section');
                    const list = document.getElementById('active-group-list');
                    if (data.success && data.groups.length > 0) {
                        section.classList.remove('d-none');
                        list.innerHTML = '';
                        data.groups.forEach(g => {
                            list.innerHTML += `
                                <div class="p-3 border rounded-4 bg-white mb-3 shadow-sm border-primary border-opacity-25">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="badge bg-primary bg-opacity-10 text-primary">NHÓM #${g.id}</span>
                                        <div class="fw-bold text-danger" id="group-timer-${g.id}" data-start="${g.rawStartTime}">00:00</div>
                                    </div>
                                    <div class="fw-bold mb-1"><i class="fas fa-users me-2 text-primary"></i>${g.quantity} xe ${g.category === 'EBike' ? 'điện' : 'đạp'}</div>
                                    <div class="small text-muted mb-2"><i class="fas fa-map-marker-alt me-2"></i>Nhận tại: ${g.startStation}</div>
                                    <div class="mb-3">
                                        <label class="small fw-bold text-muted mb-1 text-uppercase" style="font-size: 0.6rem;">Trạm trả xe thực tế</label>
                                        <select id="return-station-${g.id}" class="form-select form-select-sm rounded-3">
                                            ${stationsData.map(s => `<option value="${s.id}" ${s.id == g.endStationId ? 'selected' : ''}>${translateStationName(s.name)}</option>`).join('')}
                                        </select>
                                    </div>
                                    <button class="btn btn-success btn-sm w-100 fw-bold py-2 rounded-3 shadow-sm" onclick="handleGroupReturn(${g.id})">
                                        <i class="fas fa-undo me-2"></i>Trả xe nhóm & Thanh toán
                                    </button>
                                </div>
                            `;
                        });
                        startGroupTimers();
                    } else {
                        section.classList.add('d-none');
                    }
                });
        }

        function startGroupTimers() {
            if (window.groupTimerInterval) clearInterval(window.groupTimerInterval);
            window.groupTimerInterval = setInterval(() => {
                document.querySelectorAll('[id^="group-timer-"]').forEach(el => {
                    const start = new Date(el.dataset.start);
                    const now = new Date();
                    const diff = Math.floor((now - start) / 1000);
                    if (diff < 0) return;
                    const h = Math.floor(diff / 3600);
                    const m = Math.floor((diff % 3600) / 60);
                    const s = diff % 60;
                    el.innerText = (h > 0 ? h + ":" : "") + String(m).padStart(2, '0') + ":" + String(s).padStart(2, '0');
                });
            }, 1000);
        }

        function handleGroupReturn(groupId) {
            const endStationId = document.getElementById(`return-station-${groupId}`).value;
            if (confirm("Xác nhận bạn đã trả toàn bộ xe về trạm này?")) {
                fetch('/RentalTransactionsGroup/ReturnGroupRental', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `groupRentalId=${groupId}&endStationId=${endStationId}`
                }).then(r => r.json())
                  .then(data => {
                      if (data.success) {
                          // Lưu thông tin thanh toán vào localStorage để trang Payment hiển thị
                          localStorage.setItem('checkout_mins', data.finalBill.mins);
                          localStorage.setItem('checkout_base', data.finalBill.baseAmount);
                          localStorage.setItem('checkout_discount', data.finalBill.discount);
                          localStorage.setItem('checkout_total', data.finalBill.baseAmount); // Base amount for "rideTotal"
                          localStorage.setItem('checkout_final', data.finalBill.total);
                          localStorage.setItem('checkout_rate', data.finalBill.rate);
                          localStorage.setItem('checkout_type', `Thuê nhóm (${data.finalBill.quantity} xe)`);

                          showToast(data.message, 'success');
                          loadStationsFromDB();
                          setTimeout(() => {
                              window.location.href = '@Url.Action("Payment", "Home")';
                          }, 1000);
                      } else {
                          alert(data.message);
                      }
                  });
            }
        }

        window.onload = function() {
            // Luôn đồng bộ với cơ sở dữ liệu thay vì lấy từ LocalStorage
            localStorage.setItem('user_balance', balance);
            updateDOM();
            if (typeof initMap === 'function') initMap();
            loadStationsFromDB();
        };

        // ================= JAVASCRIPT THÊM MỚI TỪ ĐÂY =================

        // 1. Khai báo dữ liệu Tài khoản cục bộ
        let userData = {
            name: "@(ViewBag.FullName ?? "Khách hàng")",
            phone: "@(ViewBag.Phone ?? "N/A")",
            email: "@(ViewBag.Email ?? "N/A")"
        };

        // 2. Logic chuyển đổi qua lại giữa các Tab ở thanh dưới
        function switchTab(tabId, el) {
            document.querySelectorAll('.tab-pane').forEach(t => {
                t.classList.remove('active');
                t.classList.remove('d-flex'); // Bỏ flex cho tab-status khi ẩn
            });
            let targetTab = document.getElementById(tabId);
            targetTab.classList.add('active');

            // Giữ nguyên thiết kế Flex của tab trạng thái cũ
            if (tabId === 'tab-status') {
                targetTab.classList.add('d-flex');
            }

            if(el) {
                document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
                el.classList.add('active');
            }
        }

        // 3. Logic đóng/mở và cập nhật Modal Chỉnh sửa hồ sơ
        function openEditProfile() {
            document.getElementById('edit-name').value = userData.name;
            document.getElementById('edit-phone').value = userData.phone;
            document.getElementById('edit-email').value = userData.email;
            document.getElementById('edit-profile-modal').style.display = 'flex';
        }

        function closeEditProfile() {
            document.getElementById('edit-profile-modal').style.display = 'none';
        }

        function saveProfileChanges() {
            userData.name = document.getElementById('edit-name').value;
            userData.phone = document.getElementById('edit-phone').value;
            userData.email = document.getElementById('edit-email').value;

            // Gửi dữ liệu lên Server để cập nhật Database
            fetch('/Account/UpdateProfile', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                // ĐÃ FIX LỖI BỊ CẮT CỤT Ở ĐÂY:
                body: `FullName=${encodeURIComponent(userData.name)}&Phone=${encodeURIComponent(userData.phone)}&Email=${encodeURIComponent(userData.email)}`
            }).then(response => response.json())
                .then(data => {
                    if (!data.success) {
                        console.error("Lỗi khi cập nhật Database");
                    }
                });

            // Đồng bộ tên lên thanh Header
            let navName = document.getElementById('nav-user-name');
            if(navName) navName.innerText = userData.name;

            // Đồng bộ tên và email trong trang Tài khoảnD
            let profileName = document.getElementById('profile-name-display');
            if(profileName) profileName.innerText = userData.name;
            let profileEmail = document.getElementById('profile-email-display');
            if(profileEmail) profileEmail.innerText = userData.email;

            // Tự động tạo lại Ảnh đại diện theo tên mới
            let avatarUrl = `https://ui-avatars.com/api/?name=${encodeURIComponent(userData.name)}&background=00897b&color=fff&bold=true`;
            let navAvatar = document.getElementById('nav-avatar-img');
            if(navAvatar) navAvatar.src = avatarUrl;
            let mainAvatar = document.getElementById('profile-img-main');
            if(mainAvatar) mainAvatar.src = avatarUrl;

            closeEditProfile();
            showToast("Thông tin cá nhân đã được cập nhật thành công!");
        }

        // 4. Các mảng Lịch sử lưu trong LocalStorage
        let tripHistory = JSON.parse(localStorage.getItem('trip_history')) || [];
        let walletHistory = JSON.parse(localStorage.getItem('wallet_history')) || [];

        function renderAllHistory() {
            // Render Lịch sử chuyến đi
            const tripList = document.getElementById('history-list');
            if (tripList) {
                if (tripHistory.length > 0) {
                    tripList.innerHTML = '';
                    // .slice().reverse() để hiển thị giao dịch mới nhất lên đầu
                    tripHistory.slice().reverse().forEach(trip => {
                        tripList.innerHTML += `
                            <div class="trip-card">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="trip-status bg-success bg-opacity-10 text-success">HOÀN THÀNH</span>
                                    <span class="fw-bold text-danger">- ${formatMoney(trip.cost)}</span>
                                </div>
                                <div class="fw-bold small"><i class="fas fa-bicycle text-muted me-2"></i>${trip.vehicle}</div>
                                <div class="text-muted small mt-1">${trip.date} • ${trip.mins} phút sử dụng</div>
                            </div>
                        `;
                    });
                }
            }

            // Render Lịch sử Ví tiền
            const walletList = document.getElementById('wallet-history-list');
            if (walletList) {
                if (walletHistory.length > 0) {
                    walletList.innerHTML = '';
                    walletHistory.slice().reverse().forEach(txn => {
                        const isTopup = txn.type === 'topup';
                        const sign = isTopup ? '+' : '-';
                        const colorClass = isTopup ? 'text-success' : 'text-danger';
                        const icon = isTopup ? 'fa-arrow-down' : 'fa-arrow-up';
                        const title = isTopup ? 'Nạp tiền vào ví' : 'Thanh toán chuyến đi';

                        walletList.innerHTML += `
                            <div class="trip-card">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <div class="fw-bold small"><i class="fas ${icon} ${colorClass} me-2"></i>${title}</div>
                                    <span class="fw-bold ${colorClass}">${sign} ${formatMoney(txn.amount)}</span>
                                </div>
                                <div class="text-muted small mt-1" style="padding-left: 1.8rem;">${txn.date}</div>
                            </div>
                        `;
                    });
                }
            }
        }

        // Bọc (Decorate) lại hàm goToCheckOut cũ để nhét thêm tính năng ghi lịch sử
        // Đảm bảo không xóa hay chỉnh sửa hàm gốc
        const originalGoToCheckOut = goToCheckOut;
        goToCheckOut = function() {
            let totalMins = Math.ceil(rideTimeInSeconds / 60) || 1;
            let totalCost = totalMins * currentRate;
            let now = new Date().toLocaleString('vi-VN');

            // Đẩy dữ liệu vào mảng và lưu xuống LocalStorage
            tripHistory.push({ vehicle: vehicleType, mins: totalMins, cost: totalCost, date: now });
            localStorage.setItem('trip_history', JSON.stringify(tripHistory));

            walletHistory.push({ type: 'pay', amount: totalCost, date: now });
            localStorage.setItem('wallet_history', JSON.stringify(walletHistory));

            originalGoToCheckOut();
        };

        // Bọc (Decorate) lại hàm Nạp tiền cũ để nhét thêm tính năng ghi lịch sử ví và đồng bộ CSDL
        const originalProcessTopup = processTopup;
        processTopup = function() {
            let amt = parseInt(document.getElementById('topup-amount').value);
            if (amt) {
                walletHistory.push({ type: 'topup', amount: amt, date: new Date().toLocaleString('vi-VN') });
                localStorage.setItem('wallet_history', JSON.stringify(walletHistory));

                // Đồng bộ lên máy chủ
                fetch('/Account/TopUpBalance', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `amount=${amt}`
                }).then(r => r.json()).catch(e => console.log(e));
            }
            originalProcessTopup();
            // Cập nhật lại giao diện sau khi hàm gốc hoàn tất thời gian chờ (1500ms)
            setTimeout(() => renderAllHistory(), 1550);
        };

        // Bọc lại window.onload để gán dữ liệu Profile khi tải trang
        const originalOnload = window.onload;
        window.onload = function() {
            if(originalOnload) originalOnload();
            let navName = document.getElementById('nav-user-name');
            if(navName) navName.innerText = userData.name;

            // Load dữ liệu thực từ DB
            loadStationsFromDB();

            // Render toàn bộ lịch sử khi vừa vào web
            renderAllHistory();
        };
    </script>

    <!-- Script lấy thời tiết realtime cho navbar -->
    <script>
        (async function () {
            function getWeatherIcon(code) {
                if (code === 0) return '☀️';
                if (code <= 2) return '⛅';
                if (code <= 3) return '☁️';
                if (code <= 48) return '🌫️';
                if (code <= 67) return '🌧️';
                if (code <= 99) return '⛈️';
                return '🌡️';
            }
            try {
                const res = await fetch(
                    'https://api.open-meteo.com/v1/forecast?latitude=10.8231&longitude=106.6297&current_weather=true&timezone=Asia%2FHo_Chi_Minh'
                );
                const data = await res.json();
                const cw = data.current_weather;
                document.getElementById('navWeatherTemp').textContent = Math.round(cw.temperature) + '°C';
                document.getElementById('navWeatherIcon').textContent = getWeatherIcon(cw.weathercode);
            } catch (e) {
                document.getElementById('navWeatherTemp').textContent = '32°C';
                document.getElementById('navWeatherIcon').textContent = '⛅';
            }
        })();
    </script>

    <!-- ===== HỆ THỐNG ĐA NGÔN NGỮ (i18n) ===== -->
    <script>

        /* =========================
           LANGUAGE SYSTEM
        ========================= */

        // translations and t() loaded from lang.js

        function applyLanguage(lang) {

            currentLang = lang;

            localStorage.setItem(
                "saigonride_lang",
                lang
            );

            const dict =
                translations[lang] || translations.vi;

            document.querySelectorAll("[data-i18n]")
                .forEach(el => {

                    const key =
                        el.getAttribute("data-i18n");

                    if (dict[key]) {

                        el.textContent = dict[key];

                    }

                });

            updateLangButtons(lang);

            document.documentElement.lang =
                lang === "en" ? "en" : "vi";
            if (typeof renderStationsList === 'function') renderStationsList();
            if (typeof populateGroupStations === 'function') populateGroupStations();
            if (typeof updateIncentiveUI === 'function') updateIncentiveUI(stationsData);
            if (typeof renderStationsOnMap === 'function') renderStationsOnMap(stationsData);
        }

        /* =========================
           UPDATE LANGUAGE BUTTONS
        ========================= */

        function updateLangButtons(lang) {

            const btnVi =
                document.getElementById("lang-btn-vi");

            const btnEn =
                document.getElementById("lang-btn-en");

            if (!btnVi || !btnEn) return;

            if (lang === "vi") {

                btnVi.style.background = "#00838F";
                btnVi.style.color = "#fff";
                btnVi.style.boxShadow =
                    "0 2px 6px rgba(0,131,143,0.25)";

                btnEn.style.background = "transparent";
                btnEn.style.color = "#555";
                btnEn.style.boxShadow = "none";

            } else {

                btnEn.style.background = "#00838F";
                btnEn.style.color = "#fff";
                btnEn.style.boxShadow =
                    "0 2px 6px rgba(0,131,143,0.25)";

                btnVi.style.background = "transparent";
                btnVi.style.color = "#555";
                btnVi.style.boxShadow = "none";
            }
        }

        /* =========================
           SET LANGUAGE
        ========================= */

        function setLanguage(lang, event) {

            if (event) {
                event.preventDefault();
            }

            applyLanguage(lang);
        }

        /* =========================
           STATION DATA
        ========================= */

        // stationsData already declared above

        function updateIncentiveUI(data) {

            const listContainer =
                document.getElementById("notification-list");

            const badge =
                document.getElementById("promo-badge");

            if (!listContainer || !badge) return;

            const promoStations = data.filter(s => {

                if (!s.Capacity || s.Capacity <= 0)
                    return false;

                return (s.CurrentBikes / s.Capacity) < 0.2;
            });

            badge.innerText = promoStations.length;

            badge.style.display =
                promoStations.length > 0
                    ? "block"
                    : "none";

            if (promoStations.length > 0) {

                listContainer.innerHTML =
                    promoStations.map(s => `

                        <div class="card mb-3 border-warning"
                             style="background:#fffbeb;">

                            <div class="card-body p-3">

                                <h6>${s.StationName}</h6>

                                <span class="badge bg-warning text-dark">
                                    -15%
                                </span>

                                <button
                                    class="btn btn-sm btn-warning w-100 mt-2"
                                    onclick="focusOnMap(${s.Latitude}, ${s.Longitude})">

                                    Dẫn đường

                                </button>

                            </div>

                        </div>

                    `).join("");

            } else {

                listContainer.innerHTML = `

                        <div class="text-center py-3 text-muted">

                            Hiện chưa có ưu đãi

                        </div>

                    `;
            }
        }

        /* =========================
           LOAD STATIONS
        ========================= */

        // [REMOVED DUPLICATE] function loadStationsFromDB() {
        // [REMOVED DUPLICATE]         // [REMOVED DUPLICATE] fetch('/Home/GetStationsData')
        // [REMOVED DUPLICATE]         // [REMOVED DUPLICATE] .then(r => r.json())
        // [REMOVED DUPLICATE]         // [REMOVED DUPLICATE] .then(data => {
        // [REMOVED DUPLICATE]         // [REMOVED DUPLICATE] stationsData = data;
        // [REMOVED DUPLICATE]         // [REMOVED DUPLICATE] if (typeof renderStationsList === "function") {
        // [REMOVED DUPLICATE] renderStationsList();
        // [REMOVED DUPLICATE] }
        // [REMOVED DUPLICATE]         // [REMOVED DUPLICATE] if (typeof populateGroupStations === "function") {
        // [REMOVED DUPLICATE] populateGroupStations();
        // [REMOVED DUPLICATE] }
        // [REMOVED DUPLICATE]         // [REMOVED DUPLICATE] updateIncentiveUI(data);
        // [REMOVED DUPLICATE]         // [REMOVED DUPLICATE] })
        // [REMOVED DUPLICATE]         // [REMOVED DUPLICATE] .catch(err => {
        // [REMOVED DUPLICATE] console.error("Load station error:", err);
        // [REMOVED DUPLICATE] });
        // [REMOVED DUPLICATE] }

        /* =========================
           WEATHER
        ========================= */

        function checkRain(lat, lon) {

            fetch(`/Weather/IsRaining?lat=${lat}&lon=${lon}`)

                .then(r => r.json())

                .then(data => {

                    const alertBox =
                        document.getElementById("weatherAlert");

                    if (!alertBox) return;

                    alertBox.style.display =
                        data.isRaining
                            ? "block"
                            : "none";

                })

                .catch(err => {
                    console.error("Weather error:", err);
                });
        }

        /* =========================
           INIT
        ========================= */

        document.addEventListener("DOMContentLoaded", function () {

            applyLanguage(currentLang);

            // loadStationsFromDB & initMap already called in window.onload above
            // setInterval for auto-refresh
            setInterval(function () {
                fetch('/Stations/GetStationsData')
                    .then(r => r.json())
                    .then(data => {
                        stationsData.length = 0;
                        data.forEach(s => stationsData.push(s));
                        if (typeof renderStationsOnMap === 'function') renderStationsOnMap(stationsData);
                        if (typeof renderStationsList === 'function') renderStationsList();
                        updateIncentiveUI(data);
                    });
            }, 60000);

            const lat = 10.8231;
            const lon = 106.6297;

            checkRain(lat, lon);

            setInterval(() => {

                checkRain(lat, lon);

            }, 600000);

        });

    </script> 
