@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Saigon EcoRide - Ứng dụng Thuê xe</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        :root {
            --sg-primary: #00897b;
            --sg-primary-dark: #00695c;
            --sg-accent: #f59e0b;
            --sg-text: #1e293b;
            --sg-light: #f8fafc;
            --sg-danger: #ef4444;
            --sg-success: #10b981;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #e2e8f0;
            overflow: hidden;
        }

        /* ================= TOP NAVBAR (PRO UPGRADE) ================= */
        .customer-top-nav {
            background-color: #ffffff;
            height: 75px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.04);
            display: flex;
            align-items: center;
            justify-content: space-between;
            z-index: 1000;
            position: relative;
            padding: 0 2rem;
            border-bottom: 1px solid #f1f5f9;
        }

        .brand-logo-nav {
            font-size: 1.4rem;
            font-weight: 900;
            color: var(--sg-primary);
            text-decoration: none;
            display: flex;
            align-items: center;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--sg-primary), var(--sg-primary-dark));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 10px rgba(0, 137, 123, 0.2);
        }

        .nav-links {
            display: flex;
            gap: 1.8rem;
            align-items: center;
        }

        .nav-link-custom {
            color: #64748b;
            font-weight: 700;
            text-decoration: none;
            transition: color 0.2s;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
        }

            .nav-link-custom:hover, .nav-link-custom.active {
                color: var(--sg-primary);
            }

        .nav-icon-wrapper {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: #f8fafc;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid #e2e8f0;
        }

            .nav-icon-wrapper:hover {
                background: #e2e8f0;
                color: var(--sg-primary);
            }

        .user-dropdown-toggle {
            display: flex;
            align-items: center;
            cursor: pointer;
            padding: 6px 14px 6px 6px;
            border-radius: 30px;
            border: 1px solid transparent;
            transition: all 0.2s;
        }

            .user-dropdown-toggle:hover {
                background: #f8fafc;
                border-color: #e2e8f0;
            }

        .nav-avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            object-fit: cover;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .nav-user-info {
            display: flex;
            flex-direction: column;
            margin-left: 10px;
            line-height: 1.2;
        }

        .nav-user-name {
            font-weight: 800;
            font-size: 0.9rem;
            color: var(--sg-text);
        }

        .nav-user-role {
            font-size: 0.75rem;
            color: var(--sg-primary);
            font-weight: 600;
        }

        .btn-category-menu {
            background-color: #f1f5f9;
            color: var(--sg-primary-dark);
            border: 1px solid #e2e8f0;
            font-weight: 800;
            padding: 10px;
            border-radius: 12px;
            transition: all 0.2s;
            cursor: pointer;
            display: flex;
            align-items: center;
        }

            .btn-category-menu:hover {
                background-color: #e2e8f0;
            }

        /* ================= KHUNG ỨNG DỤNG ================= */
        .app-layout {
            display: flex;
            width: 100vw;
            height: calc(100vh - 75px);
            position: relative;
        }

        /* CỘT DANH SÁCH (TRÁI) */
        .vehicle-list-section {
            position: relative;
            flex-grow: 1;
            z-index: 1;
            background-color: #f1f5f9;
            overflow-y: auto;
            padding: 25px;
            scroll-behavior: smooth;
        }

            .vehicle-list-section::-webkit-scrollbar {
                width: 6px;
            }

            .vehicle-list-section::-webkit-scrollbar-thumb {
                background-color: #cbd5e1;
                border-radius: 10px;
            }

        .hero-banner {
            background: linear-gradient(135deg, var(--sg-primary) 0%, #0f766e 100%);
            border-radius: 24px;
            padding: 30px;
            color: white;
            margin-bottom: 24px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 20px rgba(0, 137, 123, 0.2);
        }

            .hero-banner::after {
                content: '\f018';
                font-family: 'Font Awesome 6 Free';
                font-weight: 900;
                position: absolute;
                right: -20px;
                bottom: -30px;
                font-size: 10rem;
                opacity: 0.1;
                transform: rotate(-15deg);
                pointer-events: none;
            }

        .search-box-static {
            display: flex;
            align-items: center;
            background: white;
            border-radius: 16px;
            padding: 16px 24px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
            transition: all 0.3s;
            border: 2px solid transparent;
            margin-bottom: 24px;
            position: sticky;
            top: 0;
            z-index: 15;
        }

            .search-box-static:focus-within {
                border-color: var(--sg-primary);
                box-shadow: 0 4px 15px rgba(0,137,123,0.1);
            }

            .search-box-static input {
                border: none;
                outline: none;
                flex-grow: 1;
                font-size: 1.05rem;
                color: var(--sg-text);
                background: transparent;
            }

        .station-card-list {
            background: white;
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.03);
            border: 1px solid #e2e8f0;
            transition: transform 0.2s;
        }

            .station-card-list:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.06);
                border-color: #cbd5e1;
            }

        .vehicle-type-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 16px;
        }

        .vehicle-type-item {
            text-align: center;
            padding: 12px 5px;
            border-radius: 14px;
            background-color: #f8fafc;
            border: 1px solid #f1f5f9;
        }

            .vehicle-type-item.has-bike {
                background-color: #ecfdf5;
                border-color: #d1fae5;
            }

            .vehicle-type-item i {
                font-size: 1.6rem;
                margin-bottom: 8px;
                display: block;
            }

            .vehicle-type-item .v-count {
                font-size: 1.3rem;
                font-weight: 900;
                color: #0f172a;
                line-height: 1;
            }

            .vehicle-type-item .v-label {
                font-size: 0.7rem;
                color: #64748b;
                text-transform: uppercase;
                font-weight: 800;
                margin-top: 4px;
            }

        /* ================= SIDEBAR ĐIỀU KHIỂN (PHẢI) ================= */
        .ui-sidebar {
            display: flex;
            flex-direction: column;
            background: white;
            z-index: 30;
            border-left: 1px solid #f1f5f9;
        }

        .sidebar-content {
            flex-grow: 1;
            padding: 24px;
            overflow-y: auto;
        }

        .wallet-card {
            background: linear-gradient(135deg, var(--sg-primary) 0%, var(--sg-primary-dark) 100%);
            border-radius: 20px;
            padding: 24px;
            color: white;
            margin-bottom: 24px;
            box-shadow: 0 10px 25px rgba(0, 137, 123, 0.2);
        }

        .wallet-balance {
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 0;
            line-height: 1.2;
        }

        .wallet-label {
            font-size: 0.8rem;
            opacity: 0.85;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }

        .btn-pay-now {
            background: var(--sg-primary);
            color: white;
            border: none;
            width: 100%;
            padding: 18px;
            border-radius: 16px;
            font-weight: 800;
            font-size: 1.15rem;
            transition: all 0.3s;
            margin-top: 10px;
            box-shadow: 0 10px 20px rgba(0,137,123,0.2);
        }

            .btn-pay-now:hover {
                background: var(--sg-primary-dark);
                transform: translateY(-2px);
            }

            .btn-pay-now.bg-danger {
                background: var(--sg-danger);
                box-shadow: 0 10px 20px rgba(239,68,68,0.2);
            }

                .btn-pay-now.bg-danger:hover {
                    background: #b91c1c;
                }

        /* ================= MODALS & DRAWER ================= */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background-color: rgba(15, 23, 42, 0.85);
            z-index: 9999;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .modal-card {
            background: white;
            color: var(--sg-text);
            padding: 32px;
            border-radius: 24px;
            width: 100%;
            max-width: 480px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            position: relative;
            max-height: 90vh;
            overflow-y: auto;
            animation: zoomIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @@keyframes zoomIn {
            from {
                opacity: 0;
                transform: scale(0.9);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .btn-close-modal {
            position: absolute;
            top: 16px;
            right: 16px;
            background: #f1f5f9;
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            color: #64748b;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10;
        }

            .btn-close-modal:hover {
                background: #e2e8f0;
                color: var(--sg-danger);
            }

        .radio-option {
            border: 2px solid #e2e8f0;
            border-radius: 16px;
            padding: 16px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            margin-bottom: 12px;
            background: #f8fafc;
        }

            .radio-option input[type="radio"] {
                display: none;
            }

            .radio-option.selected {
                border-color: var(--sg-primary);
                background: #f0fdfa;
                box-shadow: 0 4px 10px rgba(0,137,123,0.1);
            }

        .pay-logo {
            height: 35px;
            width: auto;
            object-fit: contain;
            margin-right: 15px;
        }

        .single-bike-item {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 16px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: all 0.2s;
        }

            .single-bike-item:hover {
                border-color: var(--sg-primary);
                background: white;
            }

        .bike-img {
            width: 60px;
            height: 60px;
            background: white;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
            margin-right: 15px;
        }

            .bike-img i {
                font-size: 2.2rem;
                color: var(--sg-primary);
            }

        #qr-modal {
            background-color: rgba(15, 23, 42, 0.98);
        }

        .scanner-box {
            width: 280px;
            height: 280px;
            border: 2px solid rgba(245, 158, 11, 0.3);
            position: relative;
            margin-bottom: 30px;
            border-radius: 20px;
            overflow: hidden;
            margin: 0 auto;
        }

        .scanner-line {
            width: 100%;
            height: 4px;
            background-color: var(--sg-accent);
            position: absolute;
            top: 0;
            animation: scan 1.5s infinite ease-in-out;
            box-shadow: 0 0 20px var(--sg-accent);
        }

        @@keyframes scan {
            0% {
                top: 0;
            }

            50% {
                top: 100%;
            }

            100% {
                top: 0;
            }
        }

        .toast-msg {
            position: fixed;
            top: 90px;
            left: 50%;
            transform: translateX(-50%) translateY(-50px);
            background: white;
            color: var(--sg-text);
            padding: 16px 24px;
            border-radius: 50px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 700;
            z-index: 10000;
            opacity: 0;
            transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            border: 1px solid #f1f5f9;
        }

            .toast-msg.show {
                transform: translateX(-50%) translateY(0);
                opacity: 1;
            }

        @@media (max-width: 991px) {
            .app-layout {
                flex-direction: column;
            }

            .vehicle-list-section {
                height: 100%;
                width: 100%;
                position: absolute;
                top: 0;
                left: 0;
                padding-top: 80px;
                padding-bottom: 250px;
            }

            .ui-sidebar {
                position: absolute;
                bottom: 0;
                left: 0;
                width: 100%;
                background: transparent;
                pointer-events: none;
                height: 100%;
                justify-content: space-between;
                border-left: none;
            }

            .sidebar-content {
                background: white;
                border-radius: 32px 32px 0 0;
                padding: 25px 24px 90px 24px;
                box-shadow: 0 -10px 30px rgba(0,0,0,0.1);
                pointer-events: auto;
                max-height: 55vh;
                overflow-y: auto;
            }

            .panel-drag-handle {
                width: 48px;
                height: 5px;
                background-color: #e2e8f0;
                border-radius: 3px;
                margin: 0 auto 24px auto;
                display: block;
            }
        }

        @@media (min-width: 992px) {
            .ui-sidebar {
                width: 400px;
                height: 100%;
                flex-shrink: 0;
            }

            .panel-drag-handle {
                display: none;
            }
        }

        /* ================= CSS THÊM MỚI: TABS CONTENT & BOTTOM NAV ================= */
        .tab-pane {
            display: none;
            animation: fadeIn 0.3s ease;
        }

            .tab-pane.active {
                display: block;
            }

            .tab-pane.d-flex.active {
                display: flex !important;
            }

        .trip-card {
            background: white;
            border-radius: 16px;
            padding: 16px;
            margin-bottom: 15px;
            border: 1px solid #e2e8f0;
            transition: all 0.2s;
        }

            .trip-card:hover {
                border-color: var(--sg-primary);
                box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            }

        .trip-status {
            font-size: 0.75rem;
            font-weight: 800;
            padding: 4px 10px;
            border-radius: 20px;
        }

        .profile-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .profile-img-large {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 4px solid white;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            margin-bottom: 15px;
        }

        .settings-item {
            display: flex;
            align-items: center;
            padding: 16px;
            background: #f8fafc;
            border-radius: 14px;
            margin-bottom: 12px;
            cursor: pointer;
            transition: 0.2s;
            border: 1px solid transparent;
        }

            .settings-item:hover {
                background: #f1f5f9;
                border-color: #e2e8f0;
            }

        .settings-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            color: var(--sg-primary);
        }

        .bottom-nav {
            display: flex;
            justify-content: space-around;
            padding: 15px 0;
            border-top: 1px solid #f1f5f9;
            background: white;
            margin-top: auto;
        }

        .nav-item {
            text-align: center;
            color: #94a3b8;
            cursor: pointer;
            font-size: 0.75rem;
            font-weight: 700;
            transition: 0.3s;
            flex: 1;
        }

            .nav-item i {
                font-size: 1.4rem;
                display: block;
                margin-bottom: 4px;
            }

            .nav-item.active {
                color: var(--sg-primary);
            }

        .form-control-custom {
            background: #f1f5f9;
            border: 2px solid transparent;
            border-radius: 12px;
            padding: 12px 15px;
            margin-bottom: 15px;
            width: 100%;
            transition: 0.2s;
        }

            .form-control-custom:focus {
                border-color: var(--sg-primary);
                background: white;
                outline: none;
            }
    </style>
</head>
<body>

    <nav class="customer-top-nav w-100">
        <a href="javascript:location.reload();" class="brand-logo-nav">
            <div class="logo-icon"><i class="fas fa-leaf text-white"></i></div>
            <span class="ms-2">Saigon EcoRide</span>
        </a>

        <div class="d-flex align-items-center gap-3 gap-md-4">
            <div class="nav-links d-none d-lg-flex">
                <a href="javascript:location.reload();" class="nav-link-custom active"><i class="fas fa-home me-1"></i> Trang chủ</a>
                <a href="@Url.Action("About", "Home")" class="nav-link-custom"><i class="fas fa-info-circle me-1"></i> Về chúng tôi</a>
                <a href="@Url.Action("Contact", "Home")" class="nav-link-custom"><i class="fas fa-headset me-1"></i> Hỗ trợ</a>
            </div>

            <div class="d-flex align-items-center gap-3">

                <div class="nav-icon-wrapper position-relative" onclick="openModal('notification-modal')" title="Thông báo">
                    <i class="fas fa-bell fs-5 text-muted"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white" style="font-size: 0.65rem;">2</span>
                </div>

                <div class="dropdown d-none d-md-block">
                    <div class="user-dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(ViewBag.FullName ?? "User")&background=00897b&color=fff&bold=true" alt="User" class="nav-avatar" id="nav-avatar-img">
                        <div class="nav-user-info">
                            <span class="nav-user-name" id="nav-user-name">@(ViewBag.FullName ?? "Khách hàng")</span>
                            <span class="nav-user-role"><i class="fas fa-medal text-warning"></i> Hạng Bạc</span>
                        </div>
                        <i class="fas fa-chevron-down text-muted ms-3" style="font-size: 0.8rem;"></i>
                    </div>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3 rounded-4 p-2" style="min-width: 240px;">
                        <li><h6 class="dropdown-header text-uppercase fw-bold text-muted" style="letter-spacing: 1px;">Tài khoản của tôi</h6></li>
                        <li><a class="dropdown-item py-2 fw-bold" href="#" onclick="alert('Chuyển đến Hồ sơ')"><i class="fas fa-user-circle text-primary me-2"></i> Hồ sơ cá nhân</a></li>
                        <li><a class="dropdown-item py-2 fw-bold" href="#" onclick="openModal('gateway-modal')"><i class="fas fa-wallet text-success me-2"></i> Nạp tiền ví</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2 text-danger fw-bold" href="@Url.Action("Portal", "Home")"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất an toàn</a></li>
                    </ul>
                </div>

                <button class="btn btn-outline-danger btn-sm fw-bold d-none d-lg-block ms-2 px-3 py-2" onclick="openModal('admin-login-modal')" style="border-radius: 10px;">
                    <i class="fas fa-user-shield me-1"></i> Admin
                </button>
            </div>
        </div>
    </nav>

    <div id="toast" class="toast-msg">
        <i class="fas fa-check-circle text-success fs-5"></i>
        <span id="toast-text">Thông báo</span>
    </div>

    <div class="app-layout">

        <div class="vehicle-list-section" id="scrollable-section">
            <div class="hero-banner">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill shadow-sm"><i class="fas fa-bolt me-1"></i> Dịch vụ 24/7</span>
                    <span class="fw-bold bg-black bg-opacity-25 px-3 py-1 rounded-pill" style="font-size: 0.85rem;"><i class="fas fa-location-arrow me-1"></i> Đang ở TP.HCM</span>
                </div>
                <h2 class="fw-bold mb-2">Trải nghiệm di chuyển xanh</h2>
                <p class="opacity-85 mb-4 fs-6" style="max-width: 80%;">Mở khóa xe đạp, xe điện và scooter nhanh chóng với mã QR chỉ trong 5 giây.</p>
                <div class="d-flex flex-wrap gap-3">
                    <button class="btn btn-warning fw-bold px-4 py-2 rounded-pill" onclick="handleMainAction()" style="box-shadow: 0 4px 15px rgba(245,158,11,0.4);"><i class="fas fa-qrcode me-2"></i>Thuê xe ngay</button>
                    <button class="btn btn-light fw-bold px-4 py-2 text-primary rounded-pill" onclick="document.getElementById('station-search').focus()"><i class="fas fa-map-marker-alt me-2"></i>Tìm trạm & Xe</button>
                </div>
            </div>

            <div class="d-flex justify-content-between bg-white p-3 rounded-4 shadow-sm mb-4" style="font-size: 0.9rem; font-weight: 700;">
                <span class="text-success"><i class="fas fa-bicycle fs-5 d-block mb-1"></i> 500đ/p</span>
