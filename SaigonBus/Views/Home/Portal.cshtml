        function updateTextByLang(lang) {
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (dictionary[lang][key]) el.innerHTML = dictionary[lang][key];
            });
        }

        function switchLang(lang) {
            currentLang = lang;
            localStorage.setItem('saigonride_lang', lang);
            document.getElementById('btn-vi').classList.toggle('active', lang === 'vi');
            document.getElementById('btn-en').classList.toggle('active', lang === 'en');
            updateTextByLang(lang);
        }

        document.addEventListener('DOMContentLoaded', function () {
            switchLang(currentLang);
        });
    </script>
