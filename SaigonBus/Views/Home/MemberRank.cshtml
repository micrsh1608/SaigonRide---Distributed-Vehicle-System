@{
    bool isVIP = ViewBag.IsVIP != null
        ? Convert.ToBoolean(ViewBag.IsVIP)
        : false;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xếp hạng thành viên - Saigon EcoRide</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        :root {
            --sg-primary: #00897b;
            --sg-primary-dark: #00695c;
            --sg-accent: #f59e0b;
            --sg-light: #f8fafc;
            --sg-text: #1e293b;
            --sg-muted: #64748b;
            --sg-border: #e2e8f0;
            --bronze: #b87333;
            --silver: #94a3b8;
            --gold: #f59e0b;
            --diamond: #06b6d4;
            --vip: #e91e63;
        }

        /* =========================
           BODY
        ========================= */

        body {
            background: #f1f5f9;
            font-family: 'Segoe UI', sans-serif;
            color: var(--sg-text);
        }

        .member-dashboard {
            max-width: 1400px;
            margin: auto;
            padding: 24px;
        }

        /* =========================
           NAVBAR
        ========================= */

        .custom-navbar {
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--sg-border);
            padding: 14px 0;
            box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        }

        .logo-icon {
            width: 50px;
            height: 50px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, var(--sg-primary), var(--sg-primary-dark));
            color: white;
            font-size: 20px;
        }

        .logo-text {
            font-size: 28px;
            font-weight: 800;
            color: var(--sg-primary-dark);
        }

        .navbar-nav {
            gap: 10px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 16px !important;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            color: #475569 !important;
            transition: 0.2s ease;
        }

            .nav-link i {
                color: var(--sg-primary);
            }

            .nav-link:hover,
            .nav-link.active {
                background: rgba(0,137,123,0.10);
                color: var(--sg-primary-dark) !important;
            }

        /* =========================
           CARD
        ========================= */

        /* =========================
           CURRENT RANK BACKGROUND
        ========================= */

        .card {
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.4);
            border-radius: 32px;
            padding: 34px !important;
            background: linear-gradient( 135deg, rgba(255,255,255,0.92), rgba(255,255,255,0.82));
            backdrop-filter: blur(20px);
            box-shadow: 0 20px 45px rgba(15,23,42,0.08);
            isolation: isolate;
        }

            /* glow top */

            .card::before {
                content: "";
                position: absolute;
                width: 420px;
                height: 420px;
                top: -220px;
                right: -160px;
                border-radius: 50%;
                background: radial-gradient( rgba(6,182,212,0.22), transparent 70%);
                z-index: -2;
            }

            /* glow bottom */

            .card::after {
                content: "";
                position: absolute;
                width: 320px;
                height: 320px;
                bottom: -180px;
                left: -120px;
                border-radius: 50%;
                background: radial-gradient( rgba(0,137,123,0.18), transparent 70%);
                z-index: -2;
            }

            /* animated mesh background */

            .card .rank-bg {
                position: absolute;
                inset: 0;
                background-image: linear-gradient( rgba(255,255,255,0.06) 1px, transparent 1px), linear-gradient( 90deg, rgba(255,255,255,0.06) 1px, transparent 1px);
                background-size: 28px 28px;
                mask-image: linear-gradient( to bottom, rgba(0,0,0,0.8), transparent);
                opacity: 0.6;
                z-index: -1;
            }

            /* floating blur */

            .card .floating-light {
                position: absolute;
                border-radius: 50%;
                filter: blur(40px);
                animation: floatingMove 8s ease-in-out infinite;
            }

            .card .light-1 {
                width: 140px;
                height: 140px;
                top: 20px;
                left: 40%;
                background: rgba(6,182,212,0.16);
            }

            .card .light-2 {
                width: 120px;
                height: 120px;
                bottom: 10px;
                right: 15%;
                background: rgba(245,158,11,0.12);
                animation-delay: 2s;
            }

        .text-secondary.mb-2 {
            font-size: 14px !important;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: #64748b !important;
        }

        .bg-circle {
            position: absolute;
            border-radius: 50%;
            filter: blur(40px);
            opacity: 0.8;
            z-index: -1;
        }

        .bg-primary {
            width: 260px;
            height: 260px;
            background: rgba(0,137,123,0.18);
            top: -120px;
            right: -100px;
        }

        .bg-info {
            width: 220px;
            height: 220px;
            background: rgba(6,182,212,0.16);
            bottom: -120px;
            left: -80px;
        }



        /* =========================
           CURRENT RANK
        ========================= */

        .rank-badge {
            position: relative;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 12px 22px;
            border-radius: 999px;
            background: linear-gradient( 135deg, #facc15, #f59e0b);
            color: white;
            font-size: 15px;
            font-weight: 900;
            letter-spacing: 0.5px;
            box-shadow: 0 12px 25px rgba(245,158,11,0.28);
        }

            .rank-badge::before {
                content: "";
                position: absolute;
                inset: 0;
                border-radius: inherit;
                background: linear-gradient( 120deg, transparent, rgba(255,255,255,0.45), transparent);
                transform: translateX(-100%);
                animation: shine 5s infinite;
            }

            .rank-badge i {
                font-size: 16px;
            }

        .point-number {
            font-size: 62px;
            font-weight: 900;
            line-height: 1;
            background: linear-gradient( 135deg, #00897b, #06b6d4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .point-label {
            margin-top: 8px;
            font-size: 14px;
            font-weight: 600;
            color: #64748b;
        }

        /* =========================
           PROGRESS
        ========================= */
        .progress-wrapper {
            margin-top: 30px;
        }

        .progress {
            height: 16px;
            border-radius: 999px;
            overflow: hidden;
            background: rgba(226,232,240,0.8);
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.04);
        }

        .progress-bar {
            position: relative;
            border-radius: 999px;
            background: linear-gradient( 90deg, #06b6d4, #00897b);
            overflow: hidden;
        }

            .progress-bar::after {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient( 120deg, transparent, rgba(255,255,255,0.45), transparent);
                animation: shine 3s infinite;
            }

        .small.text-secondary {
            font-size: 14px !important;
            font-weight: 600;
            color: #64748b !important;
        }

        /* =========================
           BENEFITS
        ========================= */

        .benefit-card {
            background: white;
            border: 1px solid rgba(15,23,42,0.06) !important;
            border-radius: 22px !important;
            transition: 0.25s ease;
            box-shadow: 0 6px 18px rgba(15,23,42,0.04);
        }

            .benefit-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 14px 30px rgba(15,23,42,0.08);
            }

            .benefit-card i {
                width: 56px;
                height: 56px;
                border-radius: 16px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 22px;
                color: white !important;
            }

        .fa-bolt {
            background: linear-gradient(135deg, #facc15, #f59e0b);
        }

        .fa-gift {
            background: linear-gradient(135deg, #ef4444, #ec4899);
        }

        .fa-fire {
            background: linear-gradient(135deg, #3b82f6, #06b6d4);
        }

        /* =========================
           SECTION TITLE
        ========================= */

        h5 {
            margin-top: 35px;
            font-size: 24px;
            font-weight: 900;
            color: var(--sg-primary-dark);
        }

        /* =========================
           RANK CARD
        ========================= */

        .rank-card {
            background: white;
            border: none !important;
            border-radius: 22px !important;
            transition: 0.25s ease;
            box-shadow: 0 8px 22px rgba(15,23,42,0.05);
        }

            .rank-card:hover {
                transform: translateY(-5px);
            }

            .rank-card i {
                font-size: 34px;
            }

            .rank-card small {
                color: var(--sg-muted);
            }

        .bronze i {
            color: var(--bronze);
        }

        .silver i {
            color: var(--silver);
        }

        .gold i {
            color: var(--gold);
        }

        .diamond i {
            color: var(--diamond);
        }

        /* =========================
           VIP CARD
        ========================= */

        .rank-card.vip {
            position: relative;
            background: white;
            overflow: hidden;
            box-shadow: 0 0 24px rgba(233,30,99,0.18);
        }

            .rank-card.vip::before {
                content: "";
                position: absolute;
                inset: -2px;
                border-radius: 24px;
                background: linear-gradient( 45deg, #06b6d4, #009688, #f59e0b, #e91e63);
                background-size: 400% 400%;
                animation: vipGlow 6s ease infinite;
                z-index: -1;
            }

            .rank-card.vip .fw-bold {
                color: var(--vip);
            }

            .rank-card.vip small {
                color: #f59e0b;
                font-weight: 700;
            }

        /* =========================
   LEADERBOARD
========================= */

        .leaderboard-wrapper {
            background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(255,255,255,0.88));
            border-radius: 30px;
            padding: 24px;
            box-shadow: 0 18px 40px rgba(15,23,42,0.06);
            border: 1px solid rgba(255,255,255,0.5);
            backdrop-filter: blur(18px);
            position: relative;
            overflow: hidden;
        }

            .leaderboard-wrapper::before {
                content: "";
                position: absolute;
                width: 300px;
                height: 300px;
                top: -150px;
                right: -120px;
                background: radial-gradient(rgba(6,182,212,0.16), transparent 70%);
                border-radius: 50%;
            }

            .leaderboard-wrapper::after {
                content: "";
                position: absolute;
                width: 240px;
                height: 240px;
                bottom: -120px;
                left: -100px;
                background: radial-gradient(rgba(233,30,99,0.12), transparent 70%);
                border-radius: 50%;
            }

        .leaderboard-item {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 22px;
            border-radius: 22px;
            background: rgba(255,255,255,0.88);
            margin-bottom: 16px;
            transition: 0.25s ease;
            border: 1px solid rgba(15,23,42,0.05);
            overflow: hidden;
        }

            .leaderboard-item:last-child {
                margin-bottom: 0;
            }

            .leaderboard-item:hover {
                transform: translateY(-4px) scale(1.01);
                box-shadow: 0 12px 30px rgba(15,23,42,0.08);
            }

        .leaderboard-left {
            display: flex;
            align-items: center;
            gap: 18px;
        }

        .rank-number {
            width: 56px;
            height: 56px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 900;
            color: white;
            flex-shrink: 0;
        }

        .rank-1 {
            background: linear-gradient(135deg, #facc15, #f59e0b);
            box-shadow: 0 8px 18px rgba(245,158,11,0.35);
        }

        .rank-2 {
            background: linear-gradient(135deg, #cbd5e1, #94a3b8);
            box-shadow: 0 8px 18px rgba(148,163,184,0.35);
        }

        .rank-3 {
            background: linear-gradient(135deg, #d97706, #b45309);
            box-shadow: 0 8px 18px rgba(180,83,9,0.35);
        }

        .rank-default {
            background: linear-gradient(135deg, #06b6d4, #00897b);
        }

        .leader-info h6 {
            margin: 0;
            font-size: 18px;
            font-weight: 800;
            color: #0f172a;
        }

        .leader-info span {
            font-size: 13px;
            font-weight: 600;
            color: #64748b;
        }

        .leader-points {
            text-align: right;
        }

            .leader-points .points {
                font-size: 22px;
                font-weight: 900;
                background: linear-gradient(135deg, #00897b, #06b6d4);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            .leader-points .label {
                font-size: 12px;
                font-weight: 700;
                color: #94a3b8;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        .vip-glow {
            position: absolute;
            inset: 0;
            border-radius: inherit;
            border: 1px solid rgba(245,158,11,0.25);
            pointer-events: none;
        }

        .leaderboard-crown {
            position: absolute;
            top: -6px;
            right: -6px;
            width: 34px;
            height: 34px;
            border-radius: 12px;
            background: linear-gradient(135deg, #facc15, #f59e0b);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 14px;
            box-shadow: 0 8px 16px rgba(245,158,11,0.35);
        }

        /* =========================
   MY GLOBAL RANK
========================= */

        .my-global-rank {
            margin-top: 24px;
            background: white;
            border-radius: 22px;
            padding: 22px 26px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 8px 24px rgba(15,23,42,0.06);
            border: 1px solid #eef2f7;
        }

        .rank-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .rank-icon {
            width: 56px;
            height: 56px;
            border-radius: 16px;
            background: linear-gradient(135deg,#06b6d4,#00897b);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 22px;
        }

        .rank-title {
            font-size: 18px;
            font-weight: 800;
            color: #0f172a;
        }

        .rank-desc {
            margin-top: 4px;
            color: #64748b;
            font-size: 14px;
        }

            .rank-desc span {
                color: #00897b;
                font-weight: 800;
            }

        .rank-number {
            font-size: 34px;
            font-weight: 900;
            color: #f59e0b;
        }

        /* MOBILE */

        @@media(max-width:768px) {

            .my-global-rank {
                flex-direction: column;
                align-items: flex-start;
                gap: 16px;
            }

            .rank-number {
                font-size: 28px;
            }
        }

        /* =========================
           ANIMATION
        ========================= */

        @@keyframes vipGlow {

            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        @@keyframes shine {

            100% {
                transform: translateX(200%);
            }
        }

        @@keyframes floatingMove {

            0% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-14px);
            }

            100% {
                transform: translateY(0px);
            }
        }
        /* =========================
           MOBILE
        ========================= */

        @@media(max-width: 992px) {

            .member-dashboard {
                padding: 16px;
            }

            .point-number {
                font-size: 38px;
            }

            .navbar-nav {
                margin-top: 14px;
            }
        }
    </style>
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg custom-navbar sticky-top">
        <div class="container-fluid px-4">

            <!-- LOGO -->
            <a class="navbar-brand d-flex align-items-center gap-3" href="#">
                <div class="logo-icon">
                    <i class="fas fa-motorcycle"></i>
                </div>

                <div class="logo-text">
                    <div>Saigon EcoRide</div>
                </div>
            </a>

            <!-- MOBILE BUTTON -->
            <button class="navbar-toggler border-0 shadow-none"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar">
                <i class="fas fa-bars"></i>
            </button>

            <!-- MENU -->
            <div class="collapse navbar-collapse" id="mainNavbar">

                <ul class="navbar-nav mx-auto align-items-lg-center gap-lg-2">

                    <li class="nav-item">
                        <a class="nav-link active" href="javascript:history.back()">
                            <i class="fas fa-house"></i>
                            Trang chủ
                        </a>
                    </li>

                </ul>
            </div>
        </div>
    </nav>

    <div class="member-dashboard">

        <!-- CURRENT RANK -->
        <div class="card p-4 mb-4 position-relative overflow-hidden">

            <!-- BACKGROUND -->
            <div class="rank-bg"></div>

            <div class="floating-light light-1"></div>
            <div class="floating-light light-2"></div>

            <div class="bg-circle bg-primary"></div>
            <div class="bg-circle bg-info"></div>

            <!-- TOP -->
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">

                <!-- LEFT -->
                <div>
                    <div class="text-secondary mb-2">
                        Hạng hiện tại
                    </div>

                    <div class="rank-badge @(ViewBag.IsVIP ? "vip-badge" : "")">
                        <i class="fas fa-crown"></i>

                        @(ViewBag.CurrentRankName != null
                    ? ViewBag.CurrentRankName.ToString().ToUpper()
                    : "HẠNG ĐỒNG")
                    </div>
                </div>

                <!-- RIGHT -->
                <div class="text-end">

                    <div class="point-number">
                        @String.Format("{0:N0}", ViewBag.CurrentPoints ?? 0)
                    </div>

                    <div class="point-label">
                        Tổng điểm tích lũy
                    </div>

                </div>

            </div>

            <div class="progress-wrapper mt-4">

                <div class="d-flex justify-content-between small mb-2 text-secondary">

                    <span>
                        @(isVIP ? "VIP THÀNH VIÊN" : "Tiến độ lên " + ViewBag.NextRankName)
                    </span>

                    <span>
                        @ViewBag.ProgressPercentage%
                    </span>

                </div>

                <div class="progress">
                    <div class="progress-bar"
                         style="width:@ViewBag.ProgressPercentage%">
                    </div>
                </div>

                <div class="small text-secondary mt-2">

                    @if (isVIP)
                    {
                        <span>
                            Bạn đang thuộc TOP 5 VIP hệ thống
                        </span>
                    }
                    else
                    {
                        <span>
                            Cần thêm @String.Format("{0:N0}", ViewBag.PointsToNextRank ?? 0)
                            điểm để đạt @ViewBag.NextRankName
                        </span>
                    }

                </div>

            </div>

        </div>

        <!-- BENEFITS -->
        <h5 class="mb-3">QUYỀN LỢI ĐẶC QUYỀN</h5>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="benefit-card p-3 d-flex align-items-center gap-3 border rounded">
                    <i class="fas fa-bolt fa-2x text-warning"></i>
                    <div>
                        <div class="fw-bold">Ưu tiên mở khóa xe</div>
                        <div class="text-secondary small">Xử lý nhanh hơn cho thành viên cao cấp</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="benefit-card p-3 d-flex align-items-center gap-3 border rounded">
                    <i class="fas fa-gift fa-2x text-danger"></i>
                    <div>
                        <div class="fw-bold">Voucher độc quyền</div>
                        <div class="text-secondary small">Ưu đãi và mã giảm giá hàng tháng</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="benefit-card p-3 d-flex align-items-center gap-3 border rounded">
                    <i class="fas fa-fire fa-2x text-primary"></i>
                    <div>
                        <div class="fw-bold">TOP 5 VIP</div>
                        <div class="text-secondary small">Hiển thị trên bảng xếp hạng</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- RANK LIST -->
        <h5 class="mt-4 mb-3">CẤP BẬC THÀNH VIÊN</h5>
        <div class="row g-3">
            <div class="col-md-2">
                <div class="rank-card text-center p-3 border rounded bronze">
                    <i class="fas fa-shield-halved fa-2x text-secondary"></i>
                    <div class="fw-bold mt-2">HẠNG ĐỒNG</div>
                    <small>0 điểm trở lên</small>
                </div>
            </div>
            <div class="col-md-2">
                <div class="rank-card text-center p-3 border rounded silver">
                    <i class="fas fa-dragon fa-2x text-secondary"></i>
                    <div class="fw-bold mt-2">HẠNG BẠC</div>
                    <small>1,000 điểm</small>
                </div>
            </div>
            <div class="col-md-2">
                <div class="rank-card text-center p-3 border rounded gold">
                    <i class="fas fa-crown fa-2x text-warning"></i>
                    <div class="fw-bold mt-2">HẠNG VÀNG</div>
                    <small>2,500 điểm</small>
                </div>
            </div>
            <div class="col-md-2">
                <div class="rank-card text-center p-3 border rounded diamond">
                    <i class="fas fa-gem fa-2x text-info"></i>
                    <div class="fw-bold mt-2">KIM CƯƠNG</div>
                    <small>5,000 điểm</small>
                </div>
            </div>
            <div class="col-md-2">
                <div class="rank-card text-center p-3 border rounded vip">
                    <i class="fas fa-fire-flame-curved fa-2x text-danger"></i>
                    <div class="fw-bold mt-2">VIP</div>
                    <small>Top 5 hệ thống</small>
                </div>
            </div>
        </div>

        <!-- LEADERBOARD -->
        <h5 class="mt-4 mb-3">VIP LEADERBOARD</h5>
        <div class="leaderboard-wrapper">

            @{ int rankIndex = 1; }

            @if (ViewBag.TopVips != null)
            {
                foreach (var item in ViewBag.TopVips)
                {
                    string rankClass = "rank-default";

                    if (rankIndex == 1)
                    {
                        rankClass = "rank-1";
                    }
                    else if (rankIndex == 2)
                    {
                        rankClass = "rank-2";
                    }
                    else if (rankIndex == 3)
                    {
                        rankClass = "rank-3";
                    }

                    <div class="leaderboard-item">

                        @if (rankIndex == 1)
                        {
                            <div class="leaderboard-crown">
                                <i class="fas fa-crown"></i>
                            </div>
                        }

                        <div class="vip-glow"></div>

                        <div class="leaderboard-left">

                            <div class="rank-number @rankClass">
                                #@rankIndex
                            </div>

                            <div class="leader-info">
                                <h6>@item.FullName</h6>
                                <span>TOP VIP THÀNH VIÊN</span>
                            </div>

                        </div>

                        <div class="leader-points">
                            <div class="points">
                                @item.Point.ToString("N0")
                            </div>

                            <div class="label">
                                POINTS
                            </div>
                        </div>

                    </div>

                    rankIndex++;
                }
            }

        </div>
        <div class="my-global-rank mt-4">

            <div class="rank-info">
                <div class="rank-icon">
                    <i class="fas fa-ranking-star"></i>
                </div>

                <div>
                    <div class="rank-title">
                        Xếp hạng của bạn
                    </div>

                    <div class="rank-desc">
                        <span>#@ViewBag.CurrentRankPosition</span>
                        / @ViewBag.TotalUsers
                    </div>
                </div>
            </div>

            <div class="rank-number">
                #@ViewBag.CurrentRankPosition
            </div>

        </div>


</body>
</html>