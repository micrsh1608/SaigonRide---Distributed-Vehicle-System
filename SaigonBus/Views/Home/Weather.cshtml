@{
    ViewBag.Title = "Weather - SaigonRide";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

<style>

    :root {
        --primary: #00838F;
        --primary-dark: #006064;
        --accent: #F39C12;
        --text-main: #1a2332;
        --text-muted: #6c7a8d;
        --shadow-card: 0 4px 24px rgba(0,0,0,0.08);
        --shadow-hero: 0 16px 48px rgba(0,0,0,0.18);
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        font-family: 'Be Vietnam Pro', sans-serif;
        background: linear-gradient(180deg, #f6f8fb 0%, #eef2f7 100%);
        overflow-x: hidden;
    }

    .weather-wrapper {
        display: grid;
        grid-template-columns: 260px 1fr;
        min-height: 100vh;
    }

    .weather-sidebar {
        background: linear-gradient(180deg, #00897b 0%, #00695c 100%);
        color: white;
        padding: 28px 20px;
        position: sticky;
        top: 0;
        height: 100vh;
    }

    .sidebar-logo {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
        padding-bottom: 20px;
        border-bottom: 1px solid rgba(255,255,255,0.15);
    }

    .logo-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: rgba(255,255,255,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .sidebar-label {
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        opacity: .65;
        padding: 8px 14px 4px;
        font-weight: 700;
    }

    .sidebar-divider {
        height: 1px;
        background: rgba(255,255,255,0.12);
        margin: 10px 0;
    }

    .nav-item {
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 14px;
        border-radius: 12px;
        color: rgba(255,255,255,0.8);
        text-decoration: none;
        transition: .3s;
        font-weight: 500;
    }

        .nav-item::before {
            content: '';
            position: absolute;
            left: -100%;
            top: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg,transparent,rgba(255,255,255,.15),transparent);
            transition: .45s;
        }

        .nav-item:hover::before {
            left: 100%;
        }

        .nav-item:hover,
        .nav-item.active {
            background: rgba(255,255,255,0.15);
            color: white;
            transform: translateX(6px);
        }

        .nav-item i {
            transition: .25s;
        }

        .nav-item:hover i {
            transform: rotate(-8deg) scale(1.15);
            color: #ffd166;
        }

    .weather-main {
        padding: 28px;
    }

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .search-box {
        position: relative;
        width: 420px;
    }

        .search-box input {
            width: 100%;
            padding: 13px 18px 13px 44px;
            border-radius: 50px;
            border: 1px solid #dfe6ee;
            outline: none;
            font-size: .95rem;
        }

        .search-box i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
        }

    .topbar-right {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .btn-gps,
    .btn-unit {
        border: 1px solid #dfe6ee;
        background: white;
        border-radius: 50px;
        padding: 10px 18px;
        cursor: pointer;
        font-weight: 700;
        color: var(--primary);
        transition: .25s;
    }

        .btn-gps:hover,
        .btn-unit:hover {
            background: var(--primary);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(0,131,143,.25);
        }

    .avatar-btn {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        border: none;
        background: linear-gradient(135deg,#00838F,#00ACC1);
        color: white;
        cursor: pointer;
    }

    .hero-card {
        background: linear-gradient(135deg,#00897b 0%,#00a896 40%,rgba(245,158,11,.85) 120%);
        border-radius: 24px;
        padding: 36px;
        color: white;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-bottom: 24px;
        box-shadow: var(--shadow-hero);
    }

    .hero-city {
        font-size: 1.8rem;
        font-weight: 800;
        margin-bottom: 6px;
    }

    .hero-date {
        opacity: .8;
        margin-bottom: 20px;
    }

    .hero-temp {
        font-size: 5rem;
        font-weight: 300;
    }

    .hero-right {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .hero-stat {
        background: rgba(255,255,255,0.12);
        padding: 16px;
        border-radius: 14px;
    }

    .stat-label {
        font-size: .75rem;
        opacity: .75;
        margin-bottom: 8px;
    }

    .stat-value {
        font-size: 1.2rem;
        font-weight: 700;
    }

    .w-card {
        background: white;
        border-radius: 18px;
        padding: 22px;
        box-shadow: var(--shadow-card);
        margin-bottom: 20px;
    }

    .card-title {
        font-size: .82rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 18px;
        color: var(--text-muted);
    }

    .hourly-scroll {
        display: flex;
        gap: 12px;
        overflow-x: auto;
    }

    .hourly-item {
        min-width: 85px;
        padding: 14px;
        border-radius: 14px;
        text-align: center;
        background: #f5f7fb;
        transition: .25s;
    }

        .hourly-item:hover {
            transform: translateY(-4px);
        }

        .hourly-item.active {
            background: var(--primary);
            color: white;
        }

    .cards-grid-2 {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
    }

    .daily-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px;
        border-radius: 12px;
        transition: .25s;
    }

        .daily-item:hover {
            background: #f6f9fc;
            transform: translateX(4px);
        }

    .aqi-number {
        font-size: 3rem;
        font-weight: 800;
    }

    .gps-map {
        height: 300px;
        border-radius: 14px;
        overflow: hidden;
    }

    iframe {
        border: none;
    }

    @@media(max-width:900px) {

        .weather-wrapper {
            grid-template-columns: 1fr;
        }

        .weather-sidebar {
            height: auto;
            position: static;
        }

        .hero-card {
            grid-template-columns: 1fr;
        }

        .cards-grid-2 {
            grid-template-columns: 1fr;
        }

        .search-box {
            width: 100%;
        }

        .topbar {
            flex-direction: column;
            gap: 16px;
            align-items: stretch;
        }
    }
</style>

<div class="weather-wrapper">

    <aside class="weather-sidebar">

        <div class="sidebar-logo">

            <div class="logo-icon">
                <i class="fas fa-cloud-sun"></i>
            </div>

            <div>
                <strong>SaigonRide</strong><br />
                <small style="opacity:.7">Weather</small>
            </div>

        </div>

        <div class="sidebar-label">Main</div>

        <a href="@Url.Action("UserDashboard","Home")"
           class="nav-item">

            <i class="fas fa-home"></i>
            Dashboard

        </a>

        <a href="@Url.Action("Weather","Home")"
           class="nav-item active">

            <i class="fas fa-cloud-sun"></i>
            Weather Home

        </a>

        <div class="sidebar-divider"></div>

        <div class="sidebar-label">Weather</div>

        <a href="#hourlySection" class="nav-item">

            <i class="fas fa-clock"></i>
            Hourly Forecast

        </a>

        <a href="#dailySection" class="nav-item">

            <i class="fas fa-calendar-week"></i>
            7-Day Forecast

        </a>

        <a href="#aqiSection" class="nav-item">

            <i class="fas fa-wind"></i>
            Air Quality

        </a>

        <a href="#mapSection" class="nav-item">

            <i class="fas fa-map"></i>
            Weather Radar

        </a>

        <div class="sidebar-divider"></div>

        <div class="sidebar-label">Account</div>

        <a href="@Url.Action("MemberRank","Home")"
           class="nav-item">

            <i class="fas fa-crown"></i>
            Member Ranking

        </a>

        <a href="@Url.Action("Settings","Home")"
           class="nav-item">

            <i class="fas fa-cog"></i>
            Settings

        </a>

        <div class="sidebar-divider"></div>

        <div class="sidebar-promo">

            <div style="font-size:2rem;">
                📱
            </div>

            <p>
                Download the SaigonRide Weather app for realtime updates.
            </p>

            <a href="#" class="btn-promo">
                Download App
            </a>

        </div>

    </aside>

    <main class="weather-main">

        <div class="topbar">

            <div class="search-box">

                <i class="fas fa-search"></i>

                <input type="text"
                       id="citySearch"
                       placeholder="Search city..."
                       value="Ho Chi Minh City" />

            </div>

            <div class="topbar-right">

                <button class="btn-gps" onclick="getGPS()">
                    📍 <span id="gpsLabel">My Location</span>
                </button>

                <button class="btn-unit" onclick="toggleUnit()">
                    <span id="unitLabel">°C</span>
                </button>

                <button class="avatar-btn">
                    <i class="fas fa-user"></i>
                </button>

            </div>

        </div>

        <div class="hero-card">

            <div>

                <div class="hero-city">
                    <i class="fas fa-map-marker-alt"></i>
                    <span id="heroCity">Ho Chi Minh City</span>
                </div>

                <div class="hero-date" id="heroDate">
                    Loading...
                </div>

                <div class="hero-temp">
                    <span id="heroTemp">--</span>
                    <span id="tempUnit">°C</span>
                </div>

                <div style="font-size:1.1rem;margin-top:8px;">
                    <span id="heroIcon">⛅</span>
                    <span id="heroDesc">Loading...</span>
                </div>

                <div id="heroFeels" style="margin-top:6px;opacity:.8;">
                    Feels like --°C
                </div>

            </div>

            <div class="hero-right">

                <div class="hero-stat">
                    <div class="stat-label">Humidity</div>
                    <div class="stat-value" id="heroHumidity">--%</div>
                </div>

                <div class="hero-stat">
                    <div class="stat-label">Wind</div>
                    <div class="stat-value" id="heroWind">-- km/h</div>
                </div>

                <div class="hero-stat">
                    <div class="stat-label">Visibility</div>
                    <div class="stat-value" id="heroVis">-- km</div>
                </div>

                <div class="hero-stat">
                    <div class="stat-label">Pressure</div>
                    <div class="stat-value" id="heroPressure">-- hPa</div>
                </div>

            </div>

        </div>

        <div class="w-card" id="hourlySection">

            <div class="card-title">
                Hourly Forecast
            </div>

            <div class="hourly-scroll" id="hourlyScroll"></div>

        </div>

        <div class="cards-grid-2">

            <div class="w-card" id="dailySection">

                <div class="card-title">
                    7-Day Forecast
                </div>

                <div id="dailyList"></div>

            </div>

            <div>

                <div class="w-card" id="aqiSection">

                    <div class="card-title">
                        Air Quality Index
                    </div>

                    <div class="aqi-number" id="aqiNumber">
                        --
                    </div>

                    <div id="aqiLabel">
                        Loading...
                    </div>

                    <div id="aqiDesc"
                         style="margin-top:10px;color:#666;line-height:1.7;">
                        Loading realtime air quality...
                    </div>

                </div>

                <div class="w-card" id="mapSection">

                    <div class="card-title">
                        Live Weather Radar
                    </div>

                    <div class="gps-map">
                        Loading weather radar...
                    </div>

                    <div style="margin-top:12px;">
                        Lat:
                        <strong id="gpsLat">10.8231</strong>
                    </div>

                    <div>
                        Lon:
                        <strong id="gpsLon">106.6297</strong>
                    </div>

                    <div style="margin-top:10px;color:#777;">
                        Last updated:
                        <span id="gpsTime">--:--:--</span>
                    </div>

                </div>

            </div>

        </div>

    </main>

</div>

<script>

    const DAYS = [
        'Sunday',
        'Monday',
        'Tuesday',
        'Wednesday',
        'Thursday',
        'Friday',
        'Saturday'
    ];

    const MONTHS = [
        'January',
        'February',
        'March',
        'April',
        'May',
        'June',
        'July',
        'August',
        'September',
        'October',
        'November',
        'December'
    ];

    let isCelsius = true;
    let currentWeatherData = null;
    let currentCity = 'Ho Chi Minh City';

    function convertTemp(temp) {

        return isCelsius
            ? Math.round(temp)
            : Math.round((temp * 9 / 5) + 32);
    }

    function toggleUnit() {

        isCelsius = !isCelsius;

        document.getElementById('unitLabel').textContent =
            isCelsius ? '°C' : '°F';

        if (currentWeatherData) {
            updateUI(currentWeatherData, currentCity);
        }
    }

    function weatherIcon(code) {

        if (code === 0) return '☀️';
        if (code <= 2) return '⛅';
        if (code <= 3) return '☁️';
        if (code <= 48) return '🌫️';
        if (code <= 67) return '🌧️';
        if (code <= 77) return '❄️';
        if (code <= 82) return '🌦️';

        return '⛈️';
    }

    function weatherDesc(code) {

        if (code === 0) return 'Sunny';
        if (code <= 2) return 'Partly Cloudy';
        if (code <= 3) return 'Cloudy';
        if (code <= 48) return 'Foggy';
        if (code <= 67) return 'Rain';
        if (code <= 77) return 'Snow';
        if (code <= 82) return 'Light Rain';

        return 'Thunderstorm';
    }

    async function fetchWeather(lat, lon, city) {

        try {

            const weatherUrl =
                `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&hourly=temperature_2m,relativehumidity_2m,weathercode,windspeed_10m,visibility,surface_pressure&daily=weathercode,temperature_2m_max,temperature_2m_min&current_weather=true&timezone=Asia%2FHo_Chi_Minh`;

            const airUrl =
                `https://air-quality-api.open-meteo.com/v1/air-quality?latitude=${lat}&longitude=${lon}&hourly=us_aqi,pm10,pm2_5,carbon_monoxide,nitrogen_dioxide,ozone`;

            const [weatherRes, airRes] = await Promise.all([
                fetch(weatherUrl),
                fetch(airUrl)
            ]);

            const weatherData = await weatherRes.json();
            const airData = await airRes.json();

            currentWeatherData = weatherData;
            currentCity = city;

            updateUI(weatherData, city);
            updateAirQuality(airData);
            updateWeatherMap(lat, lon);

        } catch (e) {

            console.error(e);
        }
    }

    function updateUI(data, city) {

        const now = new Date();

        document.getElementById('heroCity').textContent = city;

        document.getElementById('heroDate').textContent =
            `${DAYS[now.getDay()]}, ${now.getDate()} ${MONTHS[now.getMonth()]} ${now.getFullYear()}`;

        document.getElementById('heroTemp').textContent =
            convertTemp(data.current_weather.temperature);

        document.getElementById('tempUnit').textContent =
            isCelsius ? '°C' : '°F';

        document.getElementById('heroIcon').textContent =
            weatherIcon(data.current_weather.weathercode);

        document.getElementById('heroDesc').textContent =
            weatherDesc(data.current_weather.weathercode);

        document.getElementById('heroFeels').textContent =
            `Feels like ${convertTemp(data.current_weather.temperature - 2)}${isCelsius ? '°C' : '°F'}`;

        document.getElementById('heroHumidity').textContent =
            data.hourly.relativehumidity_2m[0] + '%';

        document.getElementById('heroWind').textContent =
            Math.round(data.current_weather.windspeed) + ' km/h';

        document.getElementById('heroVis').textContent =
            Math.round(data.hourly.visibility[0] / 1000) + ' km';

        document.getElementById('heroPressure').textContent =
            Math.round(data.hourly.surface_pressure[0]) + ' hPa';

        let hourlyHtml = '';

        for (let i = 0; i < 12; i++) {

            hourlyHtml += `
                <div class="hourly-item ${i === 0 ? 'active' : ''}">

                    <div>
                        ${i === 0 ? 'Now' : i + ':00'}
                    </div>

                    <div style="font-size:1.5rem;margin:6px 0;">
                        ${weatherIcon(data.hourly.weathercode[i])}
                    </div>

                    <div>
                        ${convertTemp(data.hourly.temperature_2m[i])}${isCelsius ? '°C' : '°F'}
                    </div>

                </div>
            `;
        }

        document.getElementById('hourlyScroll').innerHTML = hourlyHtml;

        let dailyHtml = '';

        for (let i = 0; i < 7; i++) {

            dailyHtml += `
                <div class="daily-item">

                    <div>
                        ${i === 0 ? 'Today' : DAYS[(now.getDay() + i) % 7]}
                    </div>

                    <div>
                        ${weatherIcon(data.daily.weathercode[i])}
                    </div>

                    <div>
                        ${weatherDesc(data.daily.weathercode[i])}
                    </div>

                    <div>
                        <strong>
                            ${convertTemp(data.daily.temperature_2m_max[i])}${isCelsius ? '°C' : '°F'}
                        </strong>
                        /
                        ${convertTemp(data.daily.temperature_2m_min[i])}${isCelsius ? '°C' : '°F'}
                    </div>

                </div>
            `;
        }

        document.getElementById('dailyList').innerHTML = dailyHtml;
    }

    function updateAirQuality(data) {

        const aqi = data.hourly.us_aqi[0];

        let label = '';
        let color = '';
        let desc = '';

        if (aqi <= 50) {

            label = 'Good';
            color = '#22c55e';
            desc = 'Air quality is satisfactory.';

        } else if (aqi <= 100) {

            label = 'Moderate';
            color = '#eab308';
            desc = 'Acceptable air quality.';

        } else if (aqi <= 150) {

            label = 'Unhealthy for Sensitive';
            color = '#f97316';
            desc = 'Sensitive groups may feel effects.';

        } else if (aqi <= 200) {

            label = 'Unhealthy';
            color = '#ef4444';
            desc = 'Everyone may experience health effects.';

        } else {

            label = 'Very Unhealthy';
            color = '#7e22ce';
            desc = 'Health alert conditions.';
        }

        document.getElementById('aqiNumber').textContent = aqi;

        document.getElementById('aqiNumber').style.color = color;

        document.getElementById('aqiLabel').textContent = label;

        document.getElementById('aqiDesc').innerHTML = `
            ${desc}

            <div style="margin-top:14px;font-size:.9rem;line-height:1.8;">
                <div>PM2.5: <strong>${data.hourly.pm2_5[0]}</strong></div>
                <div>PM10: <strong>${data.hourly.pm10[0]}</strong></div>
                <div>Ozone: <strong>${data.hourly.ozone[0]}</strong></div>
                <div>CO: <strong>${data.hourly.carbon_monoxide[0]}</strong></div>
            </div>
        `;
    }

    function updateWeatherMap(lat, lon) {

        document.querySelector('.gps-map').innerHTML = `
            <iframe
                width="100%"
                height="100%"
                loading="lazy"
                allowfullscreen
                src="https://embed.windy.com/embed2.html?lat=${lat}&lon=${lon}&detailLat=${lat}&detailLon=${lon}&width=650&height=450&zoom=7&level=surface&overlay=rain&product=ecmwf&menu=true&message=true&marker=true&calendar=now&pressure=true&type=map&location=coordinates&detail=true&metricWind=default&metricTemp=default">
            </iframe>
        `;
    }

    function getGPS() {

        document.getElementById('gpsLabel').textContent =
            'Locating...';

        if (!navigator.geolocation) {

            alert('Browser does not support GPS');
            return;
        }

        navigator.geolocation.getCurrentPosition(pos => {

            const lat = pos.coords.latitude;
            const lon = pos.coords.longitude;

            document.getElementById('gpsLat').textContent =
                lat.toFixed(4);

            document.getElementById('gpsLon').textContent =
                lon.toFixed(4);

            document.getElementById('gpsLabel').textContent =
                'GPS Enabled';

            fetchWeather(lat, lon, 'My Location');

        }, () => {

            document.getElementById('gpsLabel').textContent =
                'My Location';
        });
    }

    setInterval(() => {

        document.getElementById('gpsTime').textContent =
            new Date().toLocaleTimeString();

    }, 1000);

    document.getElementById('citySearch')
        .addEventListener('keydown', function (e) {

            if (e.key === 'Enter') {

                const city = this.value;

                fetchWeather(
                    10.8231,
                    106.6297,
                    city
                );
            }
        });

    fetchWeather(
        10.8231,
        106.6297,
        'Ho Chi Minh City'
    );

</script>