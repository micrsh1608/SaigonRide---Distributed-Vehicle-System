@model SaigonBus.Models.Admin

@{
    ViewBag.Title = "Đăng nhập Quản trị viên";
    // Tắt layout mặc định để thiết kế trang login riêng biệt
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - SaigonRide</title>
    <!-- Nhúng Bootstrap 5 (Giả sử project đang dùng Bootstrap) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            background-color: #f4f7f6;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            overflow: hidden;
            width: 100%;
            max-width: 450px;
        }

        .login-header {
            background-color: #00838F; /* Màu primary của SaigonRide */
            color: white;
            padding: 2rem 1.5rem;
            text-align: center;
        }

            .login-header i {
                font-size: 3rem;
                margin-bottom: 1rem;
            }

        .login-body {
            padding: 2rem;
        }

        .btn-primary-custom {
            background-color: #00838F;
            border-color: #00838F;
            color: white;
            padding: 0.6rem;
            font-weight: 600;
        }

            .btn-primary-custom:hover {
                background-color: #006064;
                border-color: #006064;
                color: white;
            }

        .input-group-text {
            background-color: transparent;
            border-right: none;
        }

        .form-control {
            border-left: none;
        }

            .form-control:focus {
                box-shadow: none;
                border-color: #ced4da;
            }

        .input-group:focus-within {
            box-shadow: 0 0 0 0.25rem rgba(0, 131, 143, 0.25);
            border-radius: 0.375rem;
        }

            .input-group:focus-within .form-control,
            .input-group:focus-within .input-group-text {
                border-color: #00838F;
            }

        .validation-summary-errors {
            color: #dc3545;
            background: #f8d7da;
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 15px;
        }

            .validation-summary-errors ul {
                margin: 0;
                padding-left: 0;
                list-style: none;
            }

        .validation-summary-valid {
            display: none !important;
        }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="login-header">
            <i class="fas fa-user-shield"></i>
            <h3 class="mb-0 fw-bold">ĐĂNG NHẬP ADMIN</h3>
            <p class="mb-0 mt-2 opacity-75">Hệ thống quản lý SaigonRide</p>
        </div>

        <div class="login-body">
            @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger" style="border-radius: 5px; font-size: 0.95rem; padding: 10px; margin-bottom: 15px;">
                        @TempData["ErrorMessage"]
                    </div>
                }

                <div class="mb-4">
                    <label class="form-label fw-bold">Tên đăng nhập</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-user text-muted"></i></span>
                        @Html.TextBoxFor(m => m.Username, new { @class = "form-control", placeholder = "Nhập tài khoản admin..." })
                    </div>
                    @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger small mt-1 d-block" })
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Mật khẩu</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Nhập mật khẩu..." })
                    </div>
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small mt-1 d-block" })
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary-custom btn-lg">
                        <i class="fas fa-sign-in-alt me-2"></i> Đăng Nhập
                    </button>
                </div>

                <div class="text-center mt-3">
                    <a href="@Url.Action("UserDashboard", "Home")" class="text-decoration-none text-muted"><i class="fas fa-arrow-left me-1"></i> Quay về trang Khách</a>
                </div>
            }
        </div>
    </div>

    <!-- Tự động focus vào ô Tên đăng nhập -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var usernameInput = document.getElementById("Username");
            if (usernameInput) {
                usernameInput.focus();
            }
        });
    </script>
</body>
</html>
