## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore is tailored for ASP.NET MVC projects.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bin/
obj/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Packages
*.nupkg
**/packages/*
!**/packages/build/

# SQL Server files
*.mdf
*.ldf
*.ndf

# Local History for Visual Studio Code
.history/

# ASP.NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Others
*.log
*.tmp
*.bak
